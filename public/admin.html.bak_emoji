                        </thead>
                        <tbody id="unbilled-tickets-body">
                            <!-- Loaded via JS -->
                        </tbody>
                    </table>
                </div>

                <div class="stats-grid responsive-grid"
                    style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
                    <div class="stats-item">
                        <label>SUBTOTAL</label>
