                                    onclick="assignDriverBulkAdmin()"><span style="font-family:'Xenotron Normal', 'Xenotron', sans-serif; margin-right:5px;">N</span> Asignar Repartidor</button>
                            </div>
                        </div>

                        <div class="table-responsive"
