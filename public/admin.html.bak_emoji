<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        window.addEventListener('error', function(e) {
            console.error("FATAL JS CRASH:\n" + e.message + "\nLinea: " + e.lineno);
        });
        window.addEventListener('unhandledrejection', function(e) {
            console.error("ASYNC CRASH:\n" + (e.reason ? e.reason.message : "Desconocida"));
        });
    </script>
    <title>novapaack.login</title>
    <meta name="description" content="Centro de control y facturación Novapack Cloud management.">
    <meta name="theme-color" content="#FF4D00">
    <meta name="robots" content="noindex, nofollow">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600&family=Inter:wght@300;400;500&display=swap"
        rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-firestore-compat.js"></script>
    <script src="firebase-config.js?v=20260310c"></script>
    <script src="libs/qrcode.min.js?v=20260310_BETA"></script>
    <script src="libs/qrious.min.js?v=20260310_BETA"></script>
    <script src="libs/html5-qrcode.min.js?v=20260310_BETA"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js?v=20260305c"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js" defer></script>
    <script src="phantom-engine.js?v=1" defer></script>

    <style>
        @font-face {
            font-family: 'Xenotron';
            src: local('Xenotron'), url('https://db.onlinewebfonts.com/t/13f990d5baee565bea4d9ff96e201c84.woff2') format('woff2');
        }

        :root {
            --brand-primary: #FF4D00;
            --brand-secondary: #FF6600;
            --bg-dark: #080808;
            --surface: rgba(18, 18, 20, 0.95);
            --surface-hover: rgba(28, 28, 31, 0.98);
            --surface-active: rgba(42, 42, 46, 1);
            --glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --text-main: #FFFFFF;
            --text-dim: #9499A3;
            --font-logo: 'Xenotron', sans-serif;
            --font-heading: 'Outfit', sans-serif;
            --font-body: 'Inter', sans-serif;
            --sidebar-width: 280px;
            --header-height: 70px;
            color-scheme: dark;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: var(--font-body);
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at 50% 50%, #1a0d00 0%, #080808 100%);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- LAYOUT --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border-glass);
            position: fixed;
            left: 0;
            top: 0;
            display: flex;
            flex-direction: column;
            z-index: 2000;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 40px;
            min-height: 100vh;
            width: calc(100% - var(--sidebar-width));
            box-sizing: border-box;
            transition: all 0.3s ease;
        }

        .main-content > div[id^="view-"] {
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
        }

        .main-content > .header,
        .main-content > div[id^="view-"] > .header {
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
        }

        /* --- SIDEBAR COMPONENTS --- */
        .sidebar-logo {
            padding: 30px 25px;
            font-family: var(--font-logo);
            font-size: 1.1rem;
            font-weight: 800;
            letter-spacing: 3px;
            color: #fff;
            text-transform: uppercase;
            cursor: pointer;
            border-bottom: 1px solid var(--border-glass);
            margin-bottom: 10px;
        }

        .sidebar-logo span {
            color: var(--brand-primary);
        }

        .nav-group {
            padding: 10px 15px;
            flex: 1;
            overflow-y: auto;
        }

        .nav-label {
            font-size: 0.7rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 25px 0 12px 15px;
            font-weight: 800;
            opacity: 0.6;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px 18px;
            margin-bottom: 6px;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.9rem;
            border-radius: 12px;
            transition: all 0.2s ease;
            cursor: pointer;
            font-weight: 500;
        }

        .nav-item span {
            font-size: 1.2rem;
        }

        .nav-item:hover {
            color: white;
            background: var(--surface-hover);
            transform: translateX(5px);
        }

        .nav-item.active {
            background: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
            color: white;
            box-shadow: 0 4px 20px rgba(255, 77, 0, 0.4);
            font-weight: 600;
        }

        .sidebar-footer {
            padding: 20px;
            border-top: 1px solid var(--border-glass);
        }

        /* --- CARDS & COMPONENTS --- */
        .card {
            background: var(--surface);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-glass);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            animation: fadeIn 0.4s ease-out;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
            flex-wrap: wrap;
            gap: 20px;
        }

        h1 {
            font-family: var(--font-heading);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0;
            color: #fff;
        }

        /* --- BUTTONS --- */
        .btn {
            border-radius: 12px;
            padding: 12px 24px;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            border: none;
            cursor: pointer;
            white-space: nowrap;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            color: white;
            box-shadow: 0 4px 15px rgba(255, 77, 0, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 77, 0, 0.4);
        }

        .btn-outline {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-glass);
            color: var(--text-dim);
        }

        .btn-danger {
            background: rgba(255, 68, 68, 0.1);
            color: #FF4444;
            border: 1px solid rgba(255, 68, 68, 0.3);
        }

        .btn-danger:hover {
            background: #FF4444;
            color: white;
        }

        .btn-success {
            background: rgba(76, 175, 80, 0.1);
            color: #4CAF50;
            border: 1px solid rgba(76, 175, 80, 0.3);
        }

        .btn-success:hover {
            background: #4CAF50;
            color: white;
        }

        .btn-outline:hover {
            border-color: var(--brand-primary);
            color: #fff;
            background: rgba(255, 77, 0, 0.1);
        }

        .btn-sm {
            padding: 8px 16px;
            font-size: 0.75rem;
        }

        /* --- FORMS --- */
        .form-group {
            margin-bottom: 20px;
        }

        label {
            font-size: 0.7rem;
            font-weight: 800;
            color: var(--brand-primary);
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 1px;
        }

        input,
        select,
        textarea,
        .form-control {
            width: 100%;
            background: #1a1a1a;
            /* Solid background to prevent transparency issues */
            border: 1px solid var(--border-glass);
            border-radius: 10px;
            color: #fff;
            padding: 12px 16px;
            font-size: 0.95rem;
            outline: none;
            transition: all 0.3s;
            font-family: inherit;
        }

        option {
            background: #1a1a1a;
            color: #fff;
            padding: 10px;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: var(--brand-primary);
            background: #252525;
            box-shadow: 0 0 0 4px rgba(255, 77, 0, 0.1);
        }

        /* --- TABLES --- */
        .user-list,
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 8px;
            margin-top: -8px;
        }

        th {
            text-align: left;
            padding: 15px 20px;
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--text-dim);
            font-weight: 800;
            letter-spacing: 1px;
        }

        td {
            padding: 18px 20px;
            background: rgba(255, 255, 255, 0.02);
            font-size: 0.9rem;
        }

        td:first-child {
            border-radius: 12px 0 0 12px;
        }

        td:last-child {
            border-radius: 0 12px 12px 0;
        }

        tr:hover td {
            background: rgba(255, 255, 255, 0.05);
        }

        /* --- MODALS --- */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 3000;
            justify-content: center;
            align-items: flex-start;
            padding: 40px 20px;
            backdrop-filter: blur(15px);
            overflow-y: auto;
        }

        .modal-content {
            background: #111;
            padding: 40px;
            border-radius: 24px;
            width: 100%;
            max-width: 800px;
            border: 1px solid var(--border-glass);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
            margin: auto;
        }

        /* --- CARDS --- */
        .card {
            background: #111;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border-glass);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.8);
        }

        /* --- MOBILE --- */
        .mobile-header {
            display: none;
            height: var(--header-height);
            background: rgba(0, 0, 0, 0.9);
            border-bottom: 1px solid var(--border-glass);
            padding: 0 20px;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        @media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.mobile-active {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
                width: 100%;
                padding: 100px 20px 20px;
            }

            .mobile-header {
                display: flex;
            }

            .btn-outline {
                display: flex;
            }

            h1 {
                font-size: 1.5rem;
            }
        }

        /* Helpers */
        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .success {
            color: #4CAF50;
            background: rgba(76, 175, 80, 0.1);
        }

        .error {
            color: #FF4444;
            background: rgba(255, 68, 68, 0.1);
        }

        .pending {
            color: #FF9800;
            background: rgba(255, 152, 0, 0.1);
        }

        /* --- RESPONSIVE UTILITIES --- */
        .table-responsive {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            margin-bottom: 1rem;
        }

        .responsive-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        @media (max-width: 768px) {
            .card {
                padding: 15px;
            }

            .modal-content {
                padding: 15px;
                border-radius: 12px;
            }

            .header {
                flex-direction: column;
                align-items: stretch;
                gap: 15px;
            }

            .header>h1 {
                text-align: center;
                font-size: 1.4rem;
            }

            .header>div {
                width: 100%;
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }

            .responsive-grid {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
</head>

<body>
    <!-- ===== ELEGANT ADMIN SPLASH ===== -->
    <div id="admin-intro">
        <div class="intro-logo-admin">NOVAPACK<span>➤</span></div>
        <div class="intro-sub-admin">CENTRO DE CONTROL</div>
        <div class="intro-bar-admin"><div class="intro-bar-fill-admin"></div></div>
        <div class="intro-status-admin">CARGANDO MÓDULOS...</div>
    </div>
    <style>
        #admin-intro {
            position:fixed; top:0; left:0; width:100%; height:100%; z-index:99999;
            background:#000; display:flex; flex-direction:column; align-items:center; justify-content:center;
            transition: opacity 0.8s ease, visibility 0.8s;
        }
        #admin-intro.fade-out { opacity:0; visibility:hidden; }
        .intro-logo-admin {
            font-family:'Xenotron', sans-serif; font-size:4rem; color:#FF4D00;
            font-weight:300; letter-spacing:12px;
            animation: adminIntroScale 1.8s ease-out forwards;
            text-shadow:0 0 30px rgba(255,77,0,0.3);
        }
        .intro-logo-admin span { color:#FF3B30; font-family:sans-serif; font-weight:900; font-size:0.8em; margin-left:5px; filter:drop-shadow(0 0 5px rgba(255,59,48,0.5)); }
        .intro-sub-admin {
            font-family:'Outfit',sans-serif; font-weight:200; font-size:0.9rem; letter-spacing:8px;
            color:#666; text-transform:uppercase; margin-top:12px;
            opacity:0; animation: adminFadeUp 1s ease 0.5s forwards;
        }
        .intro-bar-admin {
            width:200px; height:2px; background:rgba(255,255,255,0.1); border-radius:2px;
            margin-top:30px; overflow:hidden;
            opacity:0; animation: adminFadeUp 0.5s ease 0.8s forwards;
        }
        .intro-bar-fill-admin {
            width:0; height:100%; background:linear-gradient(90deg,#FF4D00,#FF6600);
            border-radius:2px; animation: adminBarFill 2s ease 0.9s forwards;
        }
        .intro-status-admin {
            font-family:'Inter',sans-serif; font-size:0.65rem; color:#444; letter-spacing:4px;
            margin-top:12px; text-transform:uppercase;
            opacity:0; animation: adminFadeUp 0.5s ease 1s forwards;
        }
        @keyframes adminIntroScale {
            0% { transform:scale(0.85); opacity:0; letter-spacing:18px; }
            100% { transform:scale(1); opacity:1; letter-spacing:3px; }
        }
        @keyframes adminFadeUp {
            from { opacity:0; transform:translateY(8px); }
            to { opacity:1; transform:translateY(0); }
        }
        @keyframes adminBarFill {
            0% { width:0; }
            100% { width:100%; }
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var intro = document.getElementById('admin-intro');
            if (intro) {
                setTimeout(function() {
                    intro.classList.add('fade-out');
                    setTimeout(function() { intro.style.display='none'; }, 800);
                }, 2800);
            }
        });
    </script>

    <!-- Mobile Header (Visible <992px) -->
    <div class="mobile-header">
        <div class="logo" onclick="location.reload()"
            style="font-family: var(--font-logo); letter-spacing: 4px; font-size: 0.8rem;">
            NOVAPACK<span>➤</span>
        </div>
        <div style="flex: 1;"></div>
        <button class="btn btn-outline btn-sm" onclick="toggleSidebar()">☰ MENU</button>
    </div>

    <!-- Premium Sidebar Navigation -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-logo" onclick="location.reload()">
            NOVAPACK<span>➤</span>
        </div>

        <div class="nav-item" id="nav-item-alerts" onclick="showView('pending-deletes');" style="display:none; color:white; background:linear-gradient(135deg, #FF3B30, #FF6B00); box-shadow: 0 4px 15px rgba(255,59,48,0.4); font-weight:900; animation: pulse 2s infinite; margin: 0 15px 15px 15px; border:2px solid #FF3B30;">
            <span>🚨</span> <div id="alert-count-text">0 ANULACIONES</div>
        </div>

        <style>
            .accordion-btn {
                background: transparent;
                color: var(--text-dim);
                cursor: pointer;
                padding: 10px 15px;
                width: 100%;
                text-align: left;
                border: none;
                outline: none;
                transition: 0.3s;
                font-weight: 700;
                font-size: 0.85rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-transform: uppercase;
                margin-top: 5px;
            }
            .accordion-btn:hover {
                color: white;
            }
            .accordion-btn.active-acc {
                color: var(--brand-primary);
            }
            .accordion-btn.active-acc::after {
                content: '▲';
            }
            .accordion-btn::after {
                content: '▼';
                font-size: 0.7rem;
                color: #888;
            }
            .accordion-content {
                background: rgba(0,0,0,0.2);
                overflow: hidden;
                transition: max-height 0.3s ease-out;
                max-height: 0;
            }
            .accordion-content .nav-item {
                padding-left: 30px;
                font-size: 0.9rem;
            }
        </style>

        <div class="nav-group" id="accordion-menu" style="margin-bottom: 30px; overflow-y:auto; flex:1;">
            <button class="accordion-btn active-acc">Facturación y Ventas</button>
            <div class="accordion-content" style="max-height: 500px;">
                <div class="nav-item" onclick="showView('adv-billing'); if(typeof window.advPopulateClientPicker === 'function') window.advPopulateClientPicker();" style="color:#FFB300; border-left: 2px solid #FFB300; font-weight:bold;">
                    <span>⚡</span> FACTURACIÓN PRO
                </div>
                
                
            </div>

            <button class="accordion-btn">Clientes y Entregas</button>
            <div class="accordion-content">
                <div class="nav-item" onclick="showView('users')">
                    <span>👥</span> Gestión Clientes
                </div>
                <div class="nav-item" onclick="showView('admin-tickets')">
                    <span>📝</span> Albaranes Manuales
                </div>
                
            </div>

            <button class="accordion-btn">Rutas Rápidas</button>
            <div class="accordion-content">
                <div class="nav-item" onclick="showView('route-monitor')">
                    <span>📍</span> Control Rutas
                </div>
                <div class="nav-item" onclick="showView('phones')">
                    <span>🔔</span> Alertas Pickup
                </div>
                <div class="nav-item" onclick="window.adminScannerMode='deliver'; showView('qr-scanner-view')">
                    <span>📷</span> Escáner Cámara
                </div>
            </div>

            <button class="accordion-btn">Sistema Local</button>
            <div class="accordion-content">
                <div class="nav-item" onclick="showView('config')">
                    <span>⚙️</span> Ajustes App
                </div>

                <div class="nav-item" onclick="showView('maintenance')">
                    <span>🛡️</span> DB Local
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const acc = document.getElementsByClassName("accordion-btn");
                for (let i = 0; i < acc.length; i++) {
                    acc[i].addEventListener("click", function() {
                        this.classList.toggle("active-acc");
                        const panel = this.nextElementSibling;
                        if (panel.style.maxHeight) {
                            panel.style.maxHeight = null;
                        } else {
                            panel.style.maxHeight = panel.scrollHeight + "px";
                        } 
                    });
                }
            });
        </script>

        <div class="sidebar-footer">
            <div class="nav-item" style="color: #ff4444;" onclick="logout()">
                <span>🚪</span> CERRAR SESIÓN
            </div>
        </div>
    </div>

    <div class="main-content" id="main-content">
        <!-- Control Tower View -->
        <div id="view-route-monitor" style="display:none;">
            <div class="header">
                <h1>Torre de Control de Rutas</h1>
                <div style="display:flex; gap:10px; flex-wrap: wrap;">
                    <button class="btn btn-outline" onclick="loadRouteMonitor()" title="Actualizar ahora">🔄 REFRESCAR</button>
                    <button class="btn btn-primary" onclick="showView('phones')" title="Configurar nombres de chóferes por ruta">⚙️ RUTAS / CARPETAS</button>
                </div>
            </div>
            <div id="route-monitor-grid" class="responsive-grid" style="margin-top:20px; padding-bottom:40px;">
                <div style="text-align:center; color:#aaa; width:100%; grid-column:1/-1;">Cargando torre de control...</div>
            </div>
        </div>

        <!-- Advanced Billing / Factucont View (PRO ERP Aesthetic) -->
        <div id="view-adv-billing" style="display:none; height:100vh; font-family: 'Segoe UI', Tahoma, Verdana, sans-serif; background:#1e1e1e; color:#d4d4d4; flex-direction:column; position:fixed; top:0; left:var(--sidebar-width); width:calc(100% - var(--sidebar-width)); z-index:9999; overflow:hidden;">
            <style>
                /* Scoped ERP Grid overrides — prevent admin global styles from bloating the compact grid */
                #view-adv-billing td { padding:2px 4px !important; background:transparent !important; border-radius:0 !important; border-bottom:1px solid #2d2d30; }
                #view-adv-billing th { padding:4px 6px !important; background:#333 !important; border-radius:0 !important; }
                #view-adv-billing tr:hover td { background:rgba(0,122,204,0.08) !important; }
                #view-adv-billing input, #view-adv-billing select { background:#2d2d30; border:1px solid #3c3c3c; color:#d4d4d4; padding:3px 6px; font-size:0.85rem; border-radius:2px; }
                #view-adv-billing input:focus { border-color:#007acc; box-shadow:none; background:#333; }
                #view-adv-billing .num-input { text-align:right; width:100%; }
                #view-adv-billing label { display:inline; margin:0; color:#9cdcfe; }
                .erp-grid-wrap { flex:1; overflow-y:auto; background:#1e1e1e; }
                #view-adv-billing #adv-grid-body tr:first-child td { padding-top:6px !important; }
                @media (max-width: 992px) {
                    #view-adv-billing { left:0 !important; width:100% !important; }
                }
            </style>
            <style>
                .adv-dropdown { position:relative; display:inline-block; }
                .adv-dropdown-btn { background:transparent; border:1px solid transparent; color:#fff; padding:4px 12px; font-size:0.85rem; cursor:pointer; border-radius:3px; display:flex; align-items:center; gap:4px; font-family:-apple-system, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif; }
                .adv-dropdown-btn:hover { background:rgba(255,255,255,0.2); }
                .adv-dropdown-menu { display:none; position:fixed; background:#1e1e2e; border:1px solid #3c3c3c; border-radius:6px; min-width:220px; z-index:99999; box-shadow:0 8px 24px rgba(0,0,0,0.5); padding:4px 0; }
                .adv-dropdown-menu.show { display:block; }
                .adv-dropdown-menu button { display:block; width:100%; text-align:left; background:transparent; border:none; color:#ccc; padding:8px 16px; font-size:0.82rem; cursor:pointer; white-space:nowrap; font-family:-apple-system, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif; }
                .adv-dropdown-menu button:hover { background:rgba(255,255,255,0.1); color:#fff; }
                .adv-dropdown-menu .dd-sep { border-top:1px solid #3c3c3c; margin:4px 0; }
                .adv-dropdown-menu .dd-label { padding:6px 16px; color:#888; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; pointer-events:none; }
            </style>
            <script>
            // Click-based dropdown toggle (avoids overflow:hidden clipping)
            document.addEventListener('click', function(e) {
                // Close all open dropdowns first
                document.querySelectorAll('.adv-dropdown-menu.show').forEach(m => {
                    if (!m.contains(e.target) && !m.previousElementSibling?.contains(e.target)) {
                        m.classList.remove('show');
                    }
                });
                // Toggle clicked dropdown
                const btn = e.target.closest('.adv-dropdown-btn');
                if (btn) {
                    const menu = btn.nextElementSibling;
                    if (menu && menu.classList.contains('adv-dropdown-menu')) {
                        const wasOpen = menu.classList.contains('show');
                        document.querySelectorAll('.adv-dropdown-menu.show').forEach(m => m.classList.remove('show'));
                        if (!wasOpen) {
                            const rect = btn.getBoundingClientRect();
                            menu.style.top = rect.bottom + 'px';
                            menu.style.left = rect.left + 'px';
                            menu.classList.add('show');
                        }
                    }
                }
            });
            </script>
            <!-- TOOLBAR PRO (Dropdown Menus) -->
            <div style="background:linear-gradient(90deg, #001f3f, #003366); padding:4px 15px; display:flex; gap:4px; align-items:center; flex-wrap:wrap; font-family:-apple-system, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif;">
                <button onclick="showView('billing'); document.getElementById('view-adv-billing').style.display='none';" style="background:transparent; border:1px solid transparent; color:white; padding:4px 10px; font-size:0.85rem; cursor:pointer;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">◀ Volver</button>
                <div style="width:1px; height:20px; background:#fff; opacity:0.3; margin:0 3px;"></div>

                <!-- FACTURAS dropdown -->
                <div class="adv-dropdown">
                    <button class="adv-dropdown-btn">📋 Facturas ▾</button>
                    <div class="adv-dropdown-menu">
                        <div class="dd-label">Crear / Editar</div>
                        <button id="btn-adv-new" onclick="if(typeof advResetForm==='function') advResetForm(); this.closest('.adv-dropdown-menu').classList.remove('show');">📄 Nueva Factura</button>
                        <button id="btn-adv-save" onclick="this.closest('.adv-dropdown-menu').classList.remove('show');">💾 Guardar / Emitir</button>
                        <div class="dd-sep"></div>
                        <div class="dd-label">Salida</div>
                        <button id="btn-adv-print" onclick="this.closest('.adv-dropdown-menu').classList.remove('show');">🖨️ Imprimir PDF</button>
                        <button id="btn-adv-email" onclick="this.closest('.adv-dropdown-menu').classList.remove('show');">✉️ Enviar a Cliente</button>
                    </div>
                </div>

                <!-- ALBARANES dropdown (NEW) -->
                <div class="adv-dropdown">
                    <button class="adv-dropdown-btn">📝 Albaranes ▾</button>
                    <div class="adv-dropdown-menu" style="min-width:260px;">
                        <div class="dd-label">Importar al Grid</div>
                        <button onclick="advOpenTicketImportModal(); this.closest('.adv-dropdown-menu').classList.remove('show');">📥 Importar Todos</button>
                        <button onclick="advImportByFilter('date'); this.closest('.adv-dropdown-menu').classList.remove('show');">📅 Importar por Fecha</button>
                        <button onclick="advImportByFilter('name'); this.closest('.adv-dropdown-menu').classList.remove('show');">👤 Importar por Nombre</button>
                        <button onclick="advImportByFilter('number'); this.closest('.adv-dropdown-menu').classList.remove('show');">🔢 Importar por Número</button>
                        <div class="dd-sep"></div>
                        <div class="dd-label">Gestión</div>
                        <button onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('manual-tickets'); this.closest('.adv-dropdown-menu').classList.remove('show');">📋 Albaranes Manuales</button>
                        <button onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('scanner'); this.closest('.adv-dropdown-menu').classList.remove('show');">📷 Escáner QR</button>
                    </div>
                </div>

                <!-- COBROS / ABONOS dropdown -->
                <div class="adv-dropdown">
                    <button class="adv-dropdown-btn">💳 Cobros ▾</button>
                    <div class="adv-dropdown-menu">
                        <button id="btn-adv-pay" onclick="this.closest('.adv-dropdown-menu').classList.remove('show');">💳 Registrar Cobro</button>
                        <button id="btn-adv-credit" onclick="this.closest('.adv-dropdown-menu').classList.remove('show');" style="color:#ffcccc;">🔄 Factura Rectificativa (Abono)</button>
                        <div class="dd-sep"></div>
                        <button id="btn-adv-search" onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('history'); this.closest('.adv-dropdown-menu').classList.remove('show');">🔍 Historial y Abonos</button>
                    </div>
                </div>

                <!-- INFORMES dropdown -->
                <div class="adv-dropdown">
                    <button class="adv-dropdown-btn">📊 Informes ▾</button>
                    <div class="adv-dropdown-menu">
                        <button onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('reports'); this.closest('.adv-dropdown-menu').classList.remove('show');" style="color:#00CED1;">📊 Listados V4</button>
                        <button id="btn-adv-conta-toggle" onclick="if(typeof window.toggleContabilidad==='function') window.toggleContabilidad(); this.closest('.adv-dropdown-menu').classList.remove('show');" style="color:#E040FB;">📚 Contabilidad</button>
                        <div class="dd-sep"></div>
                        <button id="btn-adv-tariffs-toggle" onclick="if(typeof window.toggleAdvTariffs==='function') window.toggleAdvTariffs(); this.closest('.adv-dropdown-menu').classList.remove('show');" style="color:#FFD700;">💰 Gestión de Tarifas</button>
                    </div>
                </div>

                <!-- CONTACTOS dropdown -->
                <div class="adv-dropdown">
                    <button class="adv-dropdown-btn">👥 Contactos ▾</button>
                    <div class="adv-dropdown-menu">
                        <div class="dd-label">Clientes</div>
                        <button onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('clients'); this.closest('.adv-dropdown-menu').classList.remove('show');">👥 Ver Clientes</button>
                        <button onclick="if(typeof window.advOpenClientModal==='function') window.advOpenClientModal('new'); this.closest('.adv-dropdown-menu').classList.remove('show');">➕ Nuevo Cliente</button>
                        <div class="dd-sep"></div>
                        <div class="dd-label">Proveedores</div>
                        <button onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('providers'); this.closest('.adv-dropdown-menu').classList.remove('show');">🏭 Ver Proveedores</button>
                        <button onclick="if(typeof window.toggleAdvWorkspace==='function') window.toggleAdvWorkspace('providers'); setTimeout(()=>document.getElementById('prov-name')?.focus(),300); this.closest('.adv-dropdown-menu').classList.remove('show');">➕ Nuevo Proveedor</button>
                    </div>
                </div>

                <div style="margin-left:auto; color:white; font-size:0.85rem; font-weight:bold; opacity:0.9;">⚡ Facturación PRO</div>
            </div>

            <div id="adv-billing-workspace" style="display:flex; flex-direction:column; flex:1; overflow:hidden;">
            <!-- HEADER PANEL -->
            <div style="background:#252526; border-bottom:1px solid #3c3c3c; padding:10px 15px; display:flex; gap:20px; font-size:0.85rem; align-items: flex-start; flex-wrap: wrap;">
                
                <!-- EMISORA (NUEVO) -->
                <div style="display:flex; flex-direction:column; gap:4px; width:220px;">
                    <label style="color:#9cdcfe; font-weight:bold; font-size:0.75rem; text-transform:uppercase;">Empresa Emisora (Sede)</label>
                    <select id="adv-company-picker" style="background:#3c3c3c; border:1px solid #555; color:#FFD700; font-weight:bold; padding:4px 8px; font-size:0.85rem; outline:none; cursor:pointer;" onchange="window.advCurrentCompany = this.value; if(typeof advCalculateTotals==='function') advCalculateTotals();">
                        <option value="">Cargando empresas...</option>
                        <!-- Se poblará vía JS si el admin tiene más filiales -->
                    </select>
                </div>

                <!-- CLIENTE RECEPTOR -->
                <div style="display:flex; flex-direction:column; gap:4px; width:340px; position:relative;">
                    <label style="color:#9cdcfe; font-weight:bold; font-size:0.75rem; text-transform:uppercase;">🔍 Buscar Cliente (nombre, nº, NIF...)</label>
                    <input type="text" id="adv-client-search" placeholder="Escriba para buscar..." autocomplete="off"
                        style="background:#3c3c3c; border:1px solid #555; color:#fff; padding:6px 10px; font-size:0.85rem; outline:none; border-radius:3px;">
                    <div id="adv-client-dropdown" style="display:none; position:absolute; top:100%; left:0; width:100%; max-height:280px; overflow-y:auto; background:#2d2d30; border:1px solid #007acc; border-top:none; z-index:100; box-shadow:0 8px 24px rgba(0,0,0,0.6); border-radius:0 0 4px 4px;"></div>
                    <!-- Hidden select for backward compatibility -->
                    <select id="adv-client-picker" style="display:none;" onchange="advLoadClientDetails(this.value)">
                        <option value="">--</option>
                    </select>
                </div>

                <!-- TARJETA VISUAL DATOS CLIENTE (NUEVO) -->
                <div id="adv-client-card" style="flex:1; min-width: 250px; background: rgba(0,0,0,0.2); border: 1px dashed #555; border-radius: 4px; padding: 6px 12px; display:flex; align-items: center; color: #888; font-style: italic; min-height: 48px;">
                    Seleccione un cliente para ver sus datos fiscales.
                </div>

                <!-- DATOS FACTURA -->
                <div style="display:flex; gap:15px;">
                    <div style="display:flex; flex-direction:column; gap:4px; width:130px;">
                        <label style="color:#9cdcfe; font-weight:bold; font-size:0.75rem; text-transform:uppercase;">Nº Factura</label>
                        <input type="text" id="adv-inv-number" readonly placeholder="[Auto]" style="background:#333; border:1px solid #555; color:#aaa; padding:4px 8px; font-size:0.85rem; outline:none;">
                    </div>
                    <div style="display:flex; flex-direction:column; gap:4px; width:130px;">
                        <label style="color:#9cdcfe; font-weight:bold; font-size:0.75rem; text-transform:uppercase;">Fecha Emisión</label>
                        <input type="date" id="adv-inv-date" style="background:#3c3c3c; border:1px solid #555; color:#d4d4d4; padding:4px 8px; font-size:0.85rem; outline:none;">
                    </div>
                </div>
            </div>

            <!-- GRID TOOLBAR -->
            <div style="background:#1e1e1e; padding:5px 15px; border-bottom:1px solid #3c3c3c; display:flex; gap:10px; align-items:center;">
                <div class="adv-dropdown">
                    <button class="adv-dropdown-btn" style="background:#333; border:1px solid #555; color:#d4d4d4; padding:4px 10px; font-size:0.8rem;">📥 Importar Albaranes ▾</button>
                    <div class="adv-dropdown-menu" style="min-width:240px;">
                        <button onclick="advOpenTicketImportModal(); this.closest('.adv-dropdown-menu').classList.remove('show');">📥 Todos (Sin Filtro)</button>
                        <div class="dd-sep"></div>
                        <div class="dd-label">Importar por Filtro</div>
                        <button onclick="advImportByFilter('date'); this.closest('.adv-dropdown-menu').classList.remove('show');">📅 Por Fecha</button>
                        <button onclick="advImportByFilter('name'); this.closest('.adv-dropdown-menu').classList.remove('show');">👤 Por Nombre Destinatario</button>
                        <button onclick="advImportByFilter('number'); this.closest('.adv-dropdown-menu').classList.remove('show');">🔢 Por Número de Albarán</button>
                        <div class="dd-sep"></div>
                        <button onclick="advImportSelected(); this.closest('.adv-dropdown-menu').classList.remove('show');">☑️ Solo Seleccionados</button>
                    </div>
                </div>
                <button onclick="advAddEmptyRow()" style="background:#333; border:1px solid #555; color:#d4d4d4; padding:4px 10px; font-size:0.8rem; cursor:pointer;" onmouseover="this.style.background='#444'" onmouseout="this.style.background='#333'">+ Añadir Concepto Libre</button>
                
                <div style="width:1px; height:20px; background:#fff; opacity:0.1; margin:0 5px;"></div>
                
                <button onclick="if(typeof window.advOpenDrawer==='function') window.advOpenDrawer('articles')" style="background:#094771; border:1px solid #007acc; color:#fff; padding:4px 10px; font-size:0.8rem; cursor:pointer;" onmouseover="this.style.background='#0a5a92'" onmouseout="this.style.background='#094771'">📦 Catálogo Master</button>
                <button onclick="if(typeof window.advOpenDrawer==='function') window.advOpenDrawer('tariffs')" style="background:#2E7D32; border:1px solid #4CAF50; color:#fff; padding:4px 10px; font-size:0.8rem; cursor:pointer;" onmouseover="this.style.background='#388E3C'" onmouseout="this.style.background='#2E7D32'">💰 Tarifas Cliente</button>
            </div>

            <!-- GRID AREA -->
            <div class="erp-grid-wrap" style="flex:1; overflow-y:auto; background:#1e1e1e;">
                <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
                    <thead style="position:sticky; top:0; background:#333; z-index:10; box-shadow:0 1px 0 #555;">
                        <tr>
                            <th style="padding:4px 6px; font-weight:normal; text-align:left; border-right:1px solid #555; color:#ccc;">Concepto / Descripción</th>
                            <th style="padding:4px 6px; width:70px; font-weight:normal; text-align:right; border-right:1px solid #555; color:#ccc;">Cant.</th>
                            <th style="padding:4px 6px; width:90px; font-weight:normal; text-align:right; border-right:1px solid #555; color:#ccc;">Precio Ud.</th>
                            <th style="padding:4px 6px; width:60px; font-weight:normal; text-align:right; border-right:1px solid #555; color:#ccc;">% Dto</th>
                            <th style="padding:4px 6px; width:60px; font-weight:normal; text-align:right; border-right:1px solid #555; color:#ccc;">% IVA</th>
                            <th style="padding:4px 6px; width:100px; font-weight:normal; text-align:right; border-right:1px solid #555; color:#ccc;">Importe</th>
                            <th style="padding:4px 6px; width:30px; text-align:center;"></th>
                        </tr>
                    </thead>
                    <tbody id="adv-grid-body">
                        <!-- Filled by JS -->
                        <tr id="adv-grid-empty" style="background:#1e1e1e;"><td colspan="7" style="padding:20px; text-align:center; color:#666; font-style:italic;">No hay documentos. Usa 'Importar Albaranes' para comenzar.</td></tr>
                    </tbody>
                </table>
            </div>

            <!-- FOOTER TOTALS -->
            <div style="background:#2d2d30; border-top:1px solid #444; padding:10px 20px; display:flex; justify-content:flex-end; gap:40px; font-size:0.85rem;">
                <div style="display:flex; flex-direction:column; align-items:flex-end; display:none;" id="adv-irpf-box">
                    <span style="color:#888; font-size:0.75rem; text-transform:uppercase;">Retención IRPF</span>
                    <span id="adv-irpf" style="font-family:'Consolas', monospace; font-size:1.1rem; color:#FF3B30;">0.00 €</span>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-end;">
                    <span style="color:#888; font-size:0.75rem; text-transform:uppercase;">Base Imponible</span>
                    <span id="adv-base" style="font-family:'Consolas', monospace; font-size:1.1rem; color:#d4d4d4;">0.00 €</span>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-end;">
                    <span style="color:#888; font-size:0.75rem; text-transform:uppercase;">Cuota IVA</span>
                    <span id="adv-iva" style="font-family:'Consolas', monospace; font-size:1.1rem; color:#d4d4d4;">0.00 €</span>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-end;">
                    <span style="color:#888; font-size:0.75rem; text-transform:uppercase;">TOTAL FACTURA</span>
                    <span id="adv-total" style="font-family:'Consolas', monospace; font-size:1.5rem; font-weight:bold; color:#4CAF50;">0.00 €</span>
                </div>
            </div>
            
            <!-- LATERAL DRAWER FOR CATALOGS -->
            <style>
            .adv-drawer {
                position: absolute;
                top: 0;
                right: -550px;
                width: 500px;
                height: 100%;
                background: #252526;
                border-left: 1px solid #3c3c3c;
                box-shadow: -5px 0 15px rgba(0,0,0,0.5);
                transition: right 0.3s ease-out;
                z-index: 10000;
                display: flex;
                flex-direction: column;
            }
            .adv-drawer.open {
                right: 0;
            }
            .adv-drawer-header {
                padding: 15px;
                background: #1e1e1e;
                border-bottom: 1px solid #3c3c3c;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .adv-drawer-body {
                flex: 1;
                overflow-y: auto;
                padding: 15px;
                font-size: 0.85rem;
            }
            .adv-drawer-item {
                background: #1e1e1e;
                border: 1px solid #3c3c3c;
                padding: 10px;
                margin-bottom: 10px;
                border-radius: 4px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .adv-drawer-item:hover {
                border-color: #007acc;
            }
            </style>
            <div id="adv-catalog-drawer" class="adv-drawer">
                <div class="adv-drawer-header">
                    <h3 style="margin:0; color:#fff; font-size:1rem;" id="adv-drawer-title">Catálogo</h3>
                    <button onclick="document.getElementById('adv-catalog-drawer').classList.remove('open')" style="background:transparent; border:none; color:#aaa; cursor:pointer; font-size:1.2rem; outline:none;">✖</button>
                </div>
                <div class="adv-drawer-body">
                    <input type="text" id="adv-drawer-search" placeholder="🔍 Buscar..." style="width:100%; padding:8px; margin-bottom:15px; background:#333; border:1px solid #555; color:#fff; box-sizing:border-box; outline:none;" oninput="if(typeof window.advFilterDrawer === 'function') window.advFilterDrawer(this.value)">
                    <div id="adv-drawer-list">
                        <!-- Items populated via JS -->
                        <div style="text-align:center; color:#666; padding:20px;">Seleccione una opción de catálogo</div>
                    </div>
                </div>
            </div>
            
            </div> <!-- /adv-billing-workspace -->




        <div id="adv-history-workspace" style="display:none; flex:1; overflow-y:auto; background:#1e1e1e; color:#d4d4d4;">
            <!-- PRO TOOLBAR -->
            <div style="background:#007acc; padding:5px 15px; display:flex; gap:10px; align-items:center;">
                <button onclick="if(typeof window.toggleAdvWorkspace === 'function') window.toggleAdvWorkspace('main')" style="background:transparent; border:1px solid transparent; color:white; padding:4px 10px; font-size:0.85rem; cursor:pointer;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">◀ Volver</button>
                <div style="width:1px; height:20px; background:#fff; opacity:0.3; margin:0 5px;"></div>
                <button id="tab-billing-pending" onclick="switchBillingTab('pending')" style="background:rgba(255,255,255,0.2); border:1px solid transparent; color:#4CAF50; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.3)'" onmouseout="this.style.background='rgba(255,255,255,0.2)'">⏱️ Pendiente Facturar</button>
                <button id="tab-billing-debidos" onclick="switchBillingTab('debidos')" style="background:transparent; border:1px solid transparent; color:#FF9800; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">🚚 Portes Debidos</button>
                <button id="tab-billing-issued" onclick="switchBillingTab('issued')" style="background:transparent; border:1px solid transparent; color:#FFD700; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">🧾 Facturas Emitidas</button>
                <button id="tab-billing-credit" onclick="switchBillingTab('credit')" style="background:transparent; border:1px solid transparent; color:#FF6B6B; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">📉 Abonos (NC)</button>
                <button id="tab-billing-fiscal" onclick="switchBillingTab('fiscal')" style="background:transparent; border:1px solid transparent; color:#2196F3; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">📊 Panel Fiscal</button>
                <div style="margin-left:auto; color:white; font-size:0.85rem; font-weight:bold;">🔍 Historial, Abonos y Fiscal</div>
            </div>

        <script>
            function switchBillingTab(tabId) {
                // Hide all tab content
                document.getElementById('billing-tab-pending').style.display = 'none';
                document.getElementById('billing-tab-debidos').style.display = 'none';
                document.getElementById('billing-tab-issued').style.display = 'none';
                document.getElementById('billing-tab-credit').style.display = 'none';
                document.getElementById('billing-tab-fiscal').style.display = 'none';
                
                // Reset all tab buttons to transparent
                ['pending','debidos','issued','credit','fiscal'].forEach(t => {
                    const btn = document.getElementById('tab-billing-' + t);
                    if(btn) btn.style.background = 'transparent';
                });

                // Activate selected tab
                document.getElementById('billing-tab-' + tabId).style.display = 'block';
                const activeBtn = document.getElementById('tab-billing-' + tabId);
                if(activeBtn) activeBtn.style.background = 'rgba(255,255,255,0.2)';

                // Data triggers
                if(tabId === 'credit' && typeof initCreditNotesListView === 'function') initCreditNotesListView();
                if(tabId === 'debidos' && typeof loadDebidosManager === 'function') loadDebidosManager();
                if(tabId === 'issued' && typeof loadInvoices === 'function') {
                    document.getElementById('invoice-table-body').innerHTML = '<tr><td colspan="9" style="text-align:center;">Cargando...</td></tr>';
                    setTimeout(() => loadInvoices('first'), 100);
                }
            }
        </script>

        <!-- PESTAÑA 1: PENDIENTE DE FACTURAR -->
        <div id="billing-tab-pending" style="display:block;">
            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;" style="text-align:center; padding: 40px; margin-bottom: 20px;">
                <h2 style="color:var(--brand-primary); margin-bottom: 10px; font-size:1.8rem;">📦 Albaranes Pendientes de Facturar</h2>
                <p style="color:var(--text-dim); margin-bottom: 30px; font-size:1.1rem; max-width:600px; margin-left:auto; margin-right:auto;">
                    Los albaranes listos para entrar al cierre de facturación mensual, por rutas expedidas o individuales se agrupan en el Gestor Central.
                </p>
                <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-bottom: 20px;">
                    <button class="btn btn-primary btn-lg" onclick="showView('admin-tickets'); if(typeof setAdminTicketSubView==='function') setAdminTicketSubView('list');" style="font-size:1.2rem; padding: 15px 30px;">
                        IR A GESTOR DE ALBARANES ➡️
                    </button>
                    <button class="btn btn-lg" onclick="if(typeof advInvoiceAllPending === 'function') advInvoiceAllPending(); else alert('Módulo en carga...');" style="background:linear-gradient(135deg, #FF9800, #F57C00); border:none; color:white; font-size:1.2rem; padding: 15px 30px; font-weight:bold; box-shadow:0 4px 15px rgba(255,152,0,0.4);">
                        ⚡ FACTURAR TODOS LOS PENDIENTES (Automático)
                    </button>
                </div>
            </div>
            
            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;" id="billing-config-section" style="display:none; border-left: 4px solid var(--brand-primary); margin-bottom:30px;">
                <h3 class="section-title" style="margin-top:0;">Datos Fiscales de la Empresa (NOVAPACK)</h3>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                    <div class="form-group"><label>Razón Social / Nombre Fiscal</label><input type="text" id="fiscal-name" placeholder="Ej: NOVAPACK LOGISTICA S.L."></div>
                    <div class="form-group"><label>CIF / NIF</label><input type="text" id="fiscal-cif" placeholder="Ej: B12345678"></div>
                    <div class="form-group"><label>Dirección Fiscal Completa</label><input type="text" id="fiscal-address" placeholder="Calle Ejemplo 123, 29000 Málaga"></div>
                    <div class="form-group"><label>Email de Facturación</label><input type="email" id="fiscal-email" placeholder="facturacion@novapack.info"></div>
                    <div class="form-group"><label>IBAN / Cuenta Bancaria (Para Cobros)</label><input type="text" id="fiscal-bank" placeholder="ES00 0000 0000 0000 0000 0000"></div>
                    <div class="form-group"><label>ID Acreedor SEPA (Sufijo)</label><input type="text" id="fiscal-sepa-id" placeholder="Ej: 000"></div>
                    <div class="form-group"><label>Tipo de IVA por Defecto (%)</label><input type="number" id="fiscal-iva" value="21"></div>
                    <div class="form-group"><label>Retención IRPF (%) - (Transportistas)</label><input type="number" id="fiscal-irpf" value="0"></div>
                </div>
                <button class="btn btn-primary" id="btn-save-fiscal" style="margin-top:10px;">💾 GUARDAR DATOS FISCALES</button>
            </div>
        </div>

        </div>

        <!-- PESTAÑA EXTRA: PORTES DEBIDOS -->
        <div id="billing-tab-debidos" style="display:none;">
            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;" style="margin-bottom:30px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; flex-wrap: wrap; gap: 10px;">
                    <h3 class="section-title" style="margin-top:0; color:#FF9800;">Gestor de Portes Debidos</h3>
                    <div style="display:flex; gap:10px; flex:1; max-width:400px; justify-content:flex-end;">
                        <input type="text" id="debidos-search" placeholder="🔍 Buscar por remitente, destinatario..." style="background:#1e1e1e; border:1px solid #3c3c3c; color:white; padding:8px; border-radius:4px; flex:1;" oninput="if(typeof filterDebidosList === 'function') filterDebidosList(this.value)">
                    </div>
                </div>
                <p style="color:var(--text-dim); font-size:0.9rem; margin-bottom:15px;">
                    Los albaranes "A Portes Debidos" aparecen aquí hasta que se les adjudica un destinatario (Cliente) para su facturación. Mientras estén en esta lista, <strong>no se facturarán ni al remitente ni al destinatario</strong>.
                </p>
                <div class="table-responsive">
                    <table class="user-list">
                        <thead>
                            <tr>
                                <th>FECHA</th>
                                <th>ALBARÁN</th>
                                <th>REMITENTE</th>
                                <th>DESTINATARIO</th>
                                <th>ACCIONES</th>
                            </tr>
                        </thead>
                        <tbody id="debidos-table-body">
                            <tr><td colspan="5" style="text-align:center;">Cargando portes debidos...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- Modal Asignación Debidos -->
            <div id="modal-assign-debido" class="modal" style="display:none; align-items:center; justify-content:center;">
                <div class="modal-content" style="max-width:500px; width:90%; padding:20px; background:#1e1e1e; border:1px solid #3c3c3c; border-radius:8px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; border-bottom:1px solid #3c3c3c; padding-bottom:10px;">
                        <h2 style="margin:0; color:#FF9800; font-size:1.3rem;">Adjudicar Facturación</h2>
                        <span class="close" onclick="closeAssignDebidoModal()" style="font-size:1.5rem;">&times;</span>
                    </div>
                    <p style="color:#d4d4d4; font-size:0.9rem;">
                        Selecciona a qué cliente de tu agenda deseas facturar el Albarán <strong id="assign-debido-id" style="color:#fff;"></strong>. Al asignarlo, desaparecerá de esta lista y se añadirá a la facturación de ese cliente.
                    </p>
                    <input type="hidden" id="assign-debido-ticket-id">
                    
                    <div class="form-group" style="margin-top:15px; position:relative;">
                        <label>Buscar Cliente (Nombre, NIF, Número):</label>
                        <input type="text" id="assign-debido-search" placeholder="Ej: Perez S.L." autocomplete="off" style="width:100%;">
                        <div id="assign-debido-dropdown" style="display:none; position:absolute; top:100%; left:0; right:0; background:#252526; border:1px solid #444; max-height:200px; overflow-y:auto; z-index:100; box-shadow:0 4px 10px rgba(0,0,0,0.5);"></div>
                    </div>
                    
                    <div id="assign-debido-selected-card" style="display:none; margin-top:15px; padding:15px; background:rgba(76, 175, 80, 0.1); border:1px solid #4CAF50; border-radius:4px;">
                        <div style="font-weight:bold; color:#fff;" id="assign-debido-sel-name"></div>
                        <div style="font-size:0.8rem; color:#aaa;" id="assign-debido-sel-nif"></div>
                        <input type="hidden" id="assign-debido-sel-uid">
                        <input type="hidden" id="assign-debido-sel-idnum">
                        <button class="btn btn-primary" onclick="confirmAssignDebido()" style="width:100%; margin-top:15px;">💾 CONFIRMAR ASIGNACIÓN</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- PESTAÑA 2: FACTURAS EMITIDAS -->
        <div id="billing-tab-issued" style="display:none;">
            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;" style="margin-bottom:30px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; flex-wrap: wrap; gap: 10px;">
                    <h3 class="section-title" style="margin-top:0; color:var(--brand-primary);">Registro de Facturas Emitidas</h3>
                    <button class="btn btn-secondary" id="btn-generate-sepa" style="font-size:0.8rem; font-weight:900;">📦 GENERAR REMESA SEPA</button>
                </div>
                <div class="table-responsive">
                    <table class="user-list">
                        <thead>
                            <tr>
                                <th style="width:40px;">SEL.</th>
                                <th>Nº FACTURA</th>
                                <th>FECHA</th>
                                <th>CLIENTE</th>
                                <th>BASE IMP.</th>
                                <th>IVA</th>
                                <th>IRPF</th>
                                <th>TOTAL</th>
                                <th>ACCIONES</th>
                            </tr>
                        </thead>
                        <tbody id="invoice-table-body"></tbody>
                    </table>
                </div>
                <div class="pagination-container" id="invoices-pagination" style="display:flex; justify-content:space-between; align-items:center; margin-top:15px; background:rgba(255,255,255,0.05); padding:10px; border-radius:10px; border:1px solid var(--border-glass);">
                    <button class="btn btn-outline btn-sm" onclick="loadInvoices('prev')" id="btn-invoices-prev">⬅️ Anterior</button>
                    <span id="label-invoices-page" style="font-size:0.8rem; color:var(--text-dim); font-weight:bold;">Página 1</span>
                    <button class="btn btn-outline btn-sm" onclick="loadInvoices('next')" id="btn-invoices-next">Siguiente ➡️</button>
                </div>
            </div>
        </div>

        <!-- PESTAÑA 3: ABONOS -->
        <div id="billing-tab-credit" style="display:none;">
            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;" style="margin-bottom:20px;">
                <h3 style="color:var(--brand-primary); margin-top:0; border-bottom:1px solid var(--border-glass); padding-bottom:10px;">📉 1. Generar Nuevo Abono</h3>
                <p style="color:var(--text-dim); margin-bottom:15px;">Emitir facturación negativa para devoluciones o compensaciones directas al saldo del cliente.</p>
                <div class="responsive-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
                    <div><label>Buscar Cliente</label><input type="text" id="abono-client-search" placeholder="Nombre o ID..." oninput="filterAbonoClients()"></div>
                    <div><label>Cliente Master</label><select id="abono-client-select" onchange="populateAbonoCompanySelect(this.value)"></select></div>
                    <div><label>Empresa Destino</label><select id="abono-company-select" onchange="loadAbonoForm()"><option value="">-- Elija Master Primero --</option></select></div>
                    <div><label>Motivo del Abono</label><input type="text" id="abono-reason" placeholder="Ej: Devolución..."></div>
                </div>

                <div id="abono-form-area" style="margin-top:20px; display:none;">
                    <h4 style="color:var(--brand-primary); margin-bottom:10px;">Líneas del Abono</h4>
                    <div class="responsive-grid" style="align-items: end;">
                        <div><label>Concepto</label><input type="text" id="abono-item-name" placeholder="Servicio..."></div>
                        <div><label>Base (€)</label><input type="number" id="abono-item-price" step="0.01"></div>
                        <div><label>IVA (%)</label><input type="number" id="abono-item-iva" value="21"></div>
                        <button class="btn btn-primary" onclick="addAbonoLine()" style="aspect-ratio: auto;">+ AÑADIR</button>
                    </div>
                    <div class="table-responsive">
                        <table class="user-list" style="margin-top:15px;">
                            <thead><tr><th>Concepto</th><th>Base</th><th>IVA</th><th>Total</th><th>Acciones</th></tr></thead>
                            <tbody id="abono-lines-body"></tbody>
                        </table>
                    </div>
                    <div style="text-align:right; margin-top:15px;">
                        <button class="btn btn-danger btn-lg" onclick="saveAbonoTicket()">📑 GENERAR Y ARCHIVAR ABONO</button>
                    </div>
                </div>
            </div>

            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;">
                <h3 style="color:var(--brand-primary); margin-top:0; border-bottom:1px solid var(--border-glass); padding-bottom:10px;">📔 2. Libro de Abonos Emitidos</h3>
                <div class="table-responsive mt-3">
                    <table class="user-list">
                        <thead><tr><th>Nº Abono</th><th>Fecha</th><th>Cliente</th><th>Motivo</th><th>Total</th><th>Acciones</th></tr></thead>
                        <tbody id="credit-notes-list-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- PESTAÑA 4: PANEL FISCAL -->
        <div id="billing-tab-fiscal" style="display:none;">
            <div class="card" style="background:#252526; border-color:#3c3c3c; box-shadow:none;" style="text-align:center; padding: 40px;">
                <h2 style="color:var(--brand-primary); margin-bottom: 20px;">Cálculo Global Neto (Periodo)</h2>
                <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:20px; max-width:900px; margin: 0 auto;">
                    <div style="background:rgba(76,175,80,0.1); border:1px solid var(--success); padding:30px; border-radius:12px;">
                        <div style="color:var(--success); font-size:1rem; font-weight:800;">FACTURADO</div>
                        <div style="font-size:2.5rem; font-weight:900; margin-top:10px;">— €</div>
                    </div>
                    <div style="background:rgba(255,59,48,0.1); border:1px solid #FF3B30; padding:30px; border-radius:12px;">
                        <div style="color:#FF3B30; font-size:1rem; font-weight:800;">ABONADO (NC)</div>
                        <div style="font-size:2.5rem; font-weight:900; margin-top:10px;">— €</div>
                    </div>
                    <div style="background:rgba(255,102,0,0.1); border:1px solid var(--brand-primary); padding:30px; border-radius:12px;">
                        <div style="color:var(--brand-primary); font-size:1rem; font-weight:800;">NETO REAL</div>
                        <div style="font-size:2.5rem; font-weight:900; margin-top:10px;">— €</div>
                    </div>
                </div>
                <p style="color:var(--text-dim); margin-top:30px; line-height:1.6;">
                    *Próximamente: El resumen mostrará el balance automático cruzando los ingresos reales de la ventana activa menos las rectificativas emitidas.
                </p>
            </div>
        </div>

    </div>
    

        <div id="adv-reports-workspace" style="display:none; flex:1; overflow-y:auto; background:#1e1e1e; color:#d4d4d4; flex-direction:column;">
            <!-- PRO TOOLBAR -->
            <div style="background:#007acc; padding:5px 15px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                <button onclick="if(typeof window.toggleAdvWorkspace === 'function') window.toggleAdvWorkspace('main')" style="background:transparent; border:1px solid transparent; color:white; padding:4px 10px; font-size:0.85rem; cursor:pointer;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">◀ Volver</button>
                <div style="width:1px; height:20px; background:#fff; opacity:0.3; margin:0 5px;"></div>
                <input type="date" id="rep-date-from" style="padding:3px 6px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; font-size:0.8rem;">
                <input type="date" id="rep-date-to" style="padding:3px 6px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; font-size:0.8rem;">
                <input type="text" id="rep-client-id" placeholder="ID Cliente" list="clients-datalist" style="padding:3px 6px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; font-size:0.8rem; width:100px;">
                <input type="text" id="rep-province" placeholder="Provincia" style="padding:3px 6px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; font-size:0.8rem; width:100px;">
                <button id="btn-search-reports" style="background:#4CAF50; border:none; color:white; padding:4px 15px; font-size:0.85rem; cursor:pointer; border-radius:4px; font-weight:bold;">🔍 BUSCAR</button>
                <button id="btn-print-report" onclick="if(typeof window.printReportsListado === 'function') window.printReportsListado()" style="background:transparent; border:1px solid #ccc; color:white; padding:4px 15px; font-size:0.85rem; cursor:pointer; border-radius:4px;">🖨️ Imprimir Listado</button>
                <div style="margin-left:auto; color:white; font-size:0.85rem; font-weight:bold;">📊 Listados e Informes V4</div>
            </div>
            <!-- RESULTS -->
            <div style="flex:1; padding:15px;" id="printable-reports-area">
                <div id="reports-status" style="text-align:center; padding:20px; color:#888;">Utiliza los filtros de la barra para generar un listado.</div>
                <table id="reports-table-result" style="display:none; width:100%; border-collapse:collapse;">
                    <thead style="background:#252526;">
                        <tr>
                            <th style="padding:8px; text-align:left; color:#00CED1; font-size:0.8rem;">Nº ID</th>
                            <th style="padding:8px; text-align:left; color:#00CED1; font-size:0.8rem;">ID Albarán</th>
                            <th style="padding:8px; text-align:left; color:#00CED1; font-size:0.8rem;">Fecha</th>
                            <th style="padding:8px; text-align:left; color:#00CED1; font-size:0.8rem;">Destinatario</th>
                            <th style="padding:8px; text-align:left; color:#00CED1; font-size:0.8rem;">Zona</th>
                            <th style="padding:8px; text-align:right; color:#00CED1; font-size:0.8rem;">Bultos</th>
                            <th style="padding:8px; text-align:left; color:#00CED1; font-size:0.8rem;">Tipo</th>
                            <th style="padding:8px; text-align:right; color:#00CED1; font-size:0.8rem;">Portes</th>
                            <th style="padding:8px; text-align:right; color:#00CED1; font-size:0.8rem;">Reemb.</th>
                        </tr>
                    </thead>
                    <tbody id="reports-body"></tbody>
                </table>
            </div>
        </div>


        <div id="adv-tariffs-workspace" style="display:none; flex:1; overflow-y:auto; background:#1e1e1e; color:#d4d4d4; flex-direction:column;">
            <!-- TOOLBAR (same style as PRO billing toolbar) -->
            <div style="background:#007acc; padding:5px 15px; display:flex; gap:10px; align-items:center;">
                <button onclick="if(typeof window.toggleAdvTariffs === 'function') window.toggleAdvTariffs()" style="background:transparent; border:1px solid transparent; color:white; padding:4px 10px; font-size:0.85rem; cursor:pointer;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">◀ Volver</button>
                <div style="width:1px; height:20px; background:#fff; opacity:0.3; margin:0 5px;"></div>
                <button onclick="showTariffTab('global')" id="btn-tab-global" style="background:transparent; border:1px solid transparent; color:#4CAF50; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">📊 Tarifas Globales</button>
                <button onclick="showTariffTab('client')" id="btn-tab-client" style="background:transparent; border:1px solid transparent; color:#FFD700; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">👤 Tarifas por Cliente</button>
                <button onclick="showTariffTab('articles')" id="btn-tab-articles" style="background:transparent; border:1px solid transparent; color:#2196F3; padding:4px 10px; font-size:0.85rem; cursor:pointer; font-weight:bold;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">📦 Artículos</button>
                <div style="width:1px; height:20px; background:#fff; opacity:0.3; margin:0 5px;"></div>
                <button onclick="promptNewArticlePRO()" style="background:transparent; border:1px solid transparent; color:#66BB6A; padding:4px 10px; font-size:0.85rem; cursor:pointer;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">+ Nuevo Artículo</button>
                <div style="margin-left:auto; color:white; font-size:0.85rem; font-weight:bold;">💰 Gestión de Tarifas</div>
            </div>

            <!-- TAB: Global Tariffs -->
            <div id="tariff-tab-global" style="flex:1; padding:15px;">
                <div style="background:#252526; border-bottom:1px solid #3c3c3c; padding:8px 15px; display:flex; gap:10px; align-items:center; margin-bottom:10px;">
                    <span style="color:#4CAF50; font-weight:bold; font-size:0.85rem;">📊 Tarifa Global:</span>
                    <input type="text" id="tariff-global-id" placeholder="ID o nombre de tarifa..." list="global-tariffs-datalist" style="padding:5px 10px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:200px; font-size:0.85rem;">
                    <datalist id="global-tariffs-datalist"></datalist>
                    <button class="btn btn-primary" id="btn-load-global-tariff" style="background:#4CAF50; border:none; color:white; padding:5px 15px; font-size:0.85rem; cursor:pointer; border-radius:4px;">Cargar</button>
                    <button onclick="promptCreateGlobalTariff()" style="background:transparent; border:1px solid #4CAF50; color:#4CAF50; padding:5px 12px; font-size:0.85rem; cursor:pointer; border-radius:4px;">+ Nueva Tarifa</button>
                    <button id="btn-delete-global-tariff" onclick="deleteCurrentGlobalTariff()" style="display:none; background:transparent; border:1px solid #FF3B30; color:#FF3B30; padding:5px 12px; font-size:0.85rem; cursor:pointer; border-radius:4px;">🗑️ Eliminar</button>
                </div>
                <div id="tariff-editor-area" style="display:none;">
                    <div id="sub-tariff-tabs" style="display:none; margin-bottom:10px; border-bottom:1px solid #444; padding-bottom:10px; display:flex; flex-wrap:wrap; gap:5px; align-items:center;">
                        <span style="font-size:0.8rem; font-weight:bold; color:#FFD700; margin-right:10px;">SUB-TARIFAS:</span>
                        <div id="sub-tariff-list" style="display:flex; gap:5px; flex-wrap:wrap;"></div>
                        <button onclick="promptCreateSubTariff()" style="background:transparent; border:1px solid #666; color:#ccc; padding:3px 10px; cursor:pointer; border-radius:4px; font-size:0.8rem; margin-left:auto;">+ Nueva</button>
                    </div>
                    <div style="display:flex; gap:10px; align-items:flex-start;">
                        <div style="width:280px; background:#252526; border:1px solid #444; border-radius:4px; padding:10px;">
                            <h3 id="tariff-editor-title" style="margin:0 0 8px 0; color:#FFD700; font-size:0.9rem;">Añadir Artículo</h3>
                            <input type="text" id="new-tariff-item-name" placeholder="Nombre / Medida" list="tariff-items-suggested" style="width:100%; padding:6px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; box-sizing:border-box; margin-bottom:6px; font-size:0.85rem;">
                            <input type="number" step="0.01" id="new-tariff-item-price" placeholder="Precio €" style="width:100%; padding:6px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; box-sizing:border-box; margin-bottom:6px; font-size:0.85rem;">
                            <button class="btn btn-primary" id="btn-add-tariff-item" style="width:100%; padding:8px; font-size:0.85rem;">💾 Añadir</button>
                            <div id="sub-tariff-controls" style="display:none; margin-top:10px; padding-top:10px; border-top:1px dashed #555;">
                                <button class="btn btn-danger btn-sm" onclick="deleteCurrentSubTariff()" style="width:100%; background:#FF3B30; border:none; color:white; padding:6px; cursor:pointer;">🗑️ Eliminar Sub-Tarifa</button>
                            </div>
                            <datalist id="tariff-items-suggested">
                                <option value="Sobre"><option value="Pequeño"><option value="Mediano"><option value="Grande"><option value="Palet"><option value="Bulto"><option value="Caja">
                            </datalist>
                        </div>
                        <div style="flex:1; overflow-y:auto; overflow-x:auto; max-height:calc(100vh - 280px);">
                            <table style="width:100%; border-collapse:collapse;">
                                <thead style="background:#252526;">
                                    <tr>
                                        <th style="padding:8px; color:#FFD700; font-size:0.8rem; text-align:left;">ARTÍCULO</th>
                                        <th style="padding:8px; color:#FFD700; font-size:0.8rem; text-align:right;">PRECIO</th>
                                        <th style="padding:8px; color:#FFD700; font-size:0.8rem; text-align:right;">ACCIONES</th>
                                    </tr>
                                </thead>
                                <tbody id="tariff-items-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB: Client Tariffs -->
            <div id="tariff-tab-client" style="display:none; flex:1; padding:15px;">
                <div style="background:#252526; border-bottom:1px solid #3c3c3c; padding:10px 15px; margin-bottom:10px;">
                    <!-- ROW 1: Select Client -->
                    <div style="display:flex; gap:10px; align-items:center; margin-bottom:8px;">
                        <span style="color:#FFD700; font-weight:bold; font-size:0.85rem; min-width:90px;">1️⃣ Cliente:</span>
                        <input type="text" id="tariff-client-search" placeholder="Filtrar..." style="padding:5px 10px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:150px; font-size:0.85rem;">
                        <select id="tariff-client-select" style="padding:5px 10px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; font-size:0.85rem; min-width:250px;">
                            <option value="">Seleccionar cliente...</option>
                        </select>
                    </div>
                    <!-- ROW 2: Select Global Tariff + Actions -->
                    <div style="display:flex; gap:10px; align-items:center;">
                        <span style="color:#4CAF50; font-weight:bold; font-size:0.85rem; min-width:90px;">2️⃣ Tarifa:</span>
                        <select id="import-global-tariff-select" style="padding:5px 10px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; font-size:0.85rem; min-width:180px;">
                            <option value="">Seleccionar tarifa global...</option>
                        </select>
                        <span id="tariff-preview-count" style="color:#888; font-size:0.8rem;"></span>
                        <button onclick="importGlobalToClient()" style="background:#4CAF50; border:none; color:white; padding:6px 18px; font-size:0.85rem; cursor:pointer; border-radius:4px; font-weight:bold;">✅ Adjudicar Tarifa</button>
                        <button class="btn btn-primary" id="btn-load-tariff" style="padding:6px 15px; font-size:0.85rem; cursor:pointer; border-radius:4px;">✏️ Editar Manual</button>
                    </div>
                </div>
                <div id="tariff-client-content" style="color:#888; padding:20px; text-align:center;">
                    <div style="font-size:1.1rem; margin-bottom:10px;">📋 Adjudicación de Tarifas a Clientes</div>
                    <div style="font-size:0.85rem;">1. Seleccione un <b style="color:#FFD700;">cliente</b> · 2. Seleccione una <b style="color:#4CAF50;">tarifa global</b> · 3. Pulse <b style="color:#4CAF50;">✅ Adjudicar</b></div>
                </div>
            </div>

            <!-- TAB: Articles -->
            <div id="tariff-tab-articles" style="display:none; flex:1; padding:15px;">
                <div style="background:#252526; border-bottom:1px solid #3c3c3c; padding:8px 15px; display:flex; gap:10px; align-items:center; margin-bottom:10px;">
                    <span style="color:#2196F3; font-weight:bold; font-size:0.85rem;">📦 Catálogo de Artículos</span>
                    <span id="articles-quick-count" style="color:#888; font-size:0.8rem; margin-left:10px;"></span>
                    <div style="margin-left:auto;">
                        <button onclick="promptNewArticlePRO()" style="background:#2196F3; border:none; color:white; padding:5px 15px; font-size:0.85rem; cursor:pointer; border-radius:4px; font-weight:bold;">+ Nuevo Artículo</button>
                    </div>
                </div>
                <!-- Articles CRUD inline -->
                <div id="articles-crud-panel" style="display:none; background:#252526; padding:10px 15px; margin-bottom:10px; border:1px solid #444;">
                    <input type="hidden" id="art-edit-id">
                    <div style="display:flex; gap:8px; align-items:flex-end; flex-wrap:wrap;">
                        <div><label style="display:block; font-size:0.7rem; color:#aaa;">Nombre *</label><input type="text" id="art-name" placeholder="Nombre" style="padding:5px 8px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:160px; font-size:0.85rem;"></div>
                        <div><label style="display:block; font-size:0.7rem; color:#aaa;">Descripción</label><input type="text" id="art-description" placeholder="Descripción" style="padding:5px 8px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:180px; font-size:0.85rem;"></div>
                        <div><label style="display:block; font-size:0.7rem; color:#aaa;">Precio €</label><input type="number" step="0.01" id="art-price" placeholder="0.00" style="padding:5px 8px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:80px; font-size:0.85rem;"></div>
                        <div><label style="display:block; font-size:0.7rem; color:#aaa;">Peso Kg</label><input type="number" step="0.01" id="art-weight" placeholder="0.00" style="padding:5px 8px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:80px; font-size:0.85rem;"></div>
                        <div><label style="display:block; font-size:0.7rem; color:#aaa;">Categoría</label><input type="text" id="art-category" placeholder="Categoría" style="padding:5px 8px; background:#1e1e1e; border:1px solid #555; color:white; border-radius:4px; width:120px; font-size:0.85rem;"></div>
                        <button onclick="saveArticlePRO()" style="background:#2196F3; border:none; color:white; padding:6px 15px; font-weight:bold; border-radius:4px; cursor:pointer; font-size:0.85rem;">💾 Guardar</button>
                        <button onclick="resetArticleForm(); document.getElementById('articles-crud-panel').style.display='none';" style="background:transparent; border:1px solid #666; color:#ccc; padding:6px 10px; border-radius:4px; cursor:pointer; font-size:0.85rem;">✕</button>
                    </div>
                </div>
                <table style="width:100%; border-collapse:collapse;">
                    <thead style="background:#252526;">
                        <tr>
                            <th style="padding:8px; text-align:left; color:#2196F3; font-size:0.8rem;">ARTÍCULO</th>
                            <th style="padding:8px; text-align:left; color:#2196F3; font-size:0.8rem;">DESCRIPCIÓN</th>
                            <th style="padding:8px; text-align:right; color:#2196F3; font-size:0.8rem;">PRECIO</th>
                            <th style="padding:8px; text-align:right; color:#2196F3; font-size:0.8rem;">PESO</th>
                            <th style="padding:8px; text-align:center; color:#2196F3; font-size:0.8rem;">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody id="articles-pro-body" style="color:#d4d4d4;"></tbody>
                </table>
            </div>
        </div>


            <style>

                #view-adv-billing table tbody tr { border-bottom:1px solid #333; background:#1e1e1e; }
                #view-adv-billing table tbody tr:nth-child(even) { background:#252526; }
                #view-adv-billing table tbody tr:hover { background:#062f4a; }
                #view-adv-billing table td { border-right:1px solid #444; padding:0; height:24px; }
                #view-adv-billing table td input { width:100%; height:100%; border:none; background:transparent; color:#d4d4d4; font-family:'Segoe UI', Tahoma, Verdana, sans-serif; font-size:0.85rem; padding:0 6px; box-sizing:border-box; outline:none; }
                #view-adv-billing table td input:focus { background:#094771; }
                #view-adv-billing table td input.num-input { text-align:right; font-family:'Consolas', monospace; }
                #view-adv-billing::-webkit-scrollbar { width:12px; height:12px; }
                #view-adv-billing::-webkit-scrollbar-track { background:#1e1e1e; }
                #view-adv-billing::-webkit-scrollbar-thumb { background:#424242; border: 3px solid #1e1e1e; border-radius:6px; }
                #view-adv-billing::-webkit-scrollbar-thumb:hover { background:#4f4f4f; }
            </style>
        </div>

        <!-- Welcome View (Inicial) -->
        <style>
            #view-welcome {
                position: relative;
                left: calc(var(--sidebar-width) / -2);
                width: 100%;
            }
            @media (max-width: 992px) {
                #view-welcome {
                    left: 0;
                }
            }
        </style>
        <div id="view-welcome" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:calc(100vh - 80px); text-align:center; box-sizing:border-box;">
            <div class="intro-logo-admin" style="font-size:4.5rem; margin-bottom:10px; text-shadow:0 0 30px rgba(0, 168, 255, 0.5); margin-right:-12px; display:inline-block;">NOVAPACK<span style="color:var(--brand-primary);">➤</span></div>
            <div style="color:var(--text-dim); font-size:1.4rem; letter-spacing:4px; margin-bottom:50px; text-transform:uppercase; font-weight:300; margin-right:-4px;">Administración Cloud</div>

            <div id="admin-identity-box" style="background:#1e1e2e; border:1px solid #3c3c3c; border-radius:16px; padding:40px; box-shadow:0 15px 40px rgba(0,0,0,0.6); max-width: 600px; width:100%;">
                <h3 style="color:#fff; margin-top:0; margin-bottom:30px; font-size:1.5rem; font-weight:400;">✅ ¿Quién está operando el sistema?</h3>
                <div style="display:flex; gap:20px; flex-wrap:wrap; justify-content:center;">
                    <button class="btn" style="background:linear-gradient(135deg, #005a9e, #003366); color:white; border:none; padding:15px 35px; font-size:1.2rem; border-radius:10px; font-weight:600; cursor:pointer; box-shadow:0 4px 15px rgba(0,90,158,0.4); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" onclick="setAdminIdentity('DAVID')">👤 DAVID</button>
                    <button class="btn" style="background:linear-gradient(135deg, #E040FB, #7B1FA2); color:white; border:none; padding:15px 35px; font-size:1.2rem; border-radius:10px; font-weight:600; cursor:pointer; box-shadow:0 4px 15px rgba(224,64,251,0.4); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" onclick="setAdminIdentity('MARÍA JOSÉ')">👤 MARÍA JOSÉ</button>
                    <button class="btn" style="background:linear-gradient(135deg, #FF9800, #F57C00); color:white; border:none; padding:15px 35px; font-size:1.2rem; border-radius:10px; font-weight:600; cursor:pointer; box-shadow:0 4px 15px rgba(255,152,0,0.4); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" onclick="setAdminIdentity('CLAUDIA')">👤 CLAUDIA</button>
                </div>
            </div>

            <div id="admin-welcome-msg" style="display:none; margin-top:40px; animation: fadeIn 0.5s ease-out;">
                <h2 style="color:#fff; font-size:2.5rem; margin-bottom:15px;">¡Hola, <span id="admin-name-span" style="color:var(--brand-primary);"></span>! 👋</h2>
                <p style="color:#aaa; font-size:1.2rem;">Tu identidad ha sido registrada para esta sesión.</p>
                <p style="color:#888; font-size:1rem; margin-top:10px;">Selecciona una opción en el menú lateral para comenzar a trabajar.</p>
            </div>
        </div>

        <script>
            window.adminIdentity = null;
            function setAdminIdentity(name) {
                window.adminIdentity = name;
                document.getElementById('admin-identity-box').style.display = 'none';
                document.getElementById('admin-name-span').textContent = name;
                document.getElementById('admin-welcome-msg').style.display = 'block';
                console.log("Admin Identity Set:", name);
                sessionStorage.setItem('adminActiveIdentity', name);
            }
            
            // Check session identity
            window.addEventListener('load', () => {
                const savedIdentity = sessionStorage.getItem('adminActiveIdentity');
                if(savedIdentity) {
                    setAdminIdentity(savedIdentity);
                }
                
                // Set default view on load
                setTimeout(()=> {
                    if (typeof showView === 'function') showView('welcome');
                }, 100);
            });
        </script>

        <!-- Asistente IA NOVAPACK (FAB & Modal) -->
        <div id="ai-assistant-fab" style="position:fixed; bottom:30px; right:30px; width:60px; height:60px; border-radius:30px; background:linear-gradient(135deg, var(--brand-primary), #007acc); color:white; display:flex; align-items:center; justify-content:center; font-size:1.8rem; cursor:pointer; box-shadow:0 6px 20px rgba(0, 168, 255, 0.4); z-index:9999; animation: pulse 2s infinite;" title="Asistente de IA" onclick="document.getElementById('ai-chat-modal').style.display='flex'">
            🤖
        </div>

        <div id="ai-chat-modal" style="display:none; position:fixed; bottom:100px; right:30px; width:360px; height:500px; background:#1e1e2e; border:1px solid #3c3c3c; border-radius:12px; box-shadow:0 10px 40px rgba(0,0,0,0.7); z-index:9999; flex-direction:column; overflow:hidden;">
            <!-- Chat Header -->
            <div style="background:linear-gradient(135deg, #005a9e, var(--brand-primary)); padding:15px; display:flex; justify-content:space-between; align-items:center;">
                <div style="display:flex; align-items:center; gap:10px;">
                    <span style="font-size:1.5rem;">🤖</span>
                    <div>
                        <div style="color:white; font-weight:bold; font-size:1rem;">NOVA-IA</div>
                        <div style="color:rgba(255,255,255,0.7); font-size:0.75rem;">Asistente de Administración</div>
                    </div>
                </div>
                <button onclick="document.getElementById('ai-chat-modal').style.display='none'" style="background:transparent; border:none; color:white; font-size:1.2rem; cursor:pointer;">✖</button>
            </div>
            
            <!-- Chat Body -->
            <div id="ai-chat-body" style="flex:1; padding:15px; overflow-y:auto; display:flex; flex-direction:column; gap:12px;">
                <!-- Bot Welcome Message -->
                <div style="align-self:flex-start; background:#252526; border:1px solid #3c3c3c; padding:10px 14px; border-radius:12px 12px 12px 0; color:#d4d4d4; font-size:0.9rem; max-width:85%;">
                    Hola <span class="dynamic-identity-name">Administrador</span>. Soy tu Asistente NOVAPACK.<br><br>Estoy programado para ayudarte con dudas operativas.<br><br>¿Qué necesitas consultar?
                </div>
                
                <!-- Sugerentes Rápidas -->
                <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:5px;" id="ai-suggestions-box">
                    <button class="btn btn-outline btn-sm" style="font-size:0.75rem; color:var(--brand-primary); border-color:var(--brand-primary);" onclick="sendAIPrompt('¿Cómo hago una factura Pro?')">Cómo hacer una factura Pro</button>
                    <button class="btn btn-outline btn-sm" style="font-size:0.75rem; color:var(--brand-primary); border-color:var(--brand-primary);" onclick="sendAIPrompt('¿Cómo funciona la App de Repartidor?')">App de Repartidor</button>
                    <button class="btn btn-outline btn-sm" style="font-size:0.75rem; color:var(--brand-primary); border-color:var(--brand-primary);" onclick="sendAIPrompt('¿Dónde veo los Portes Debidos?')">Portes Debidos</button>
                </div>
            </div>
            
            <!-- Chat Input -->
            <div style="padding:15px; border-top:1px solid #3c3c3c; display:flex; gap:10px; background:#181818;">
                <input type="text" id="ai-chat-input" placeholder="Pregunta sobre Novapack..." style="flex:1; background:#252526; border:1px solid #444; color:white; padding:10px 12px; border-radius:20px; outline:none; font-size:0.9rem;" onkeypress="if(event.key==='Enter') sendAIPrompt()">
                <button onclick="sendAIPrompt()" style="background:var(--brand-primary); color:white; border:none; width:40px; height:40px; border-radius:20px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:1.1rem;">➤</button>
            </div>
        </div>

        <script>
            function sendAIPrompt(textStr) {
                const input = document.getElementById('ai-chat-input');
                const text = textStr || input.value.trim();
                if(!text) return;
                
                input.value = '';
                const body = document.getElementById('ai-chat-body');
                
                // Hide suggestions
                const sugg = document.getElementById('ai-suggestions-box');
                if(sugg) sugg.style.display = 'none';

                // User Msg
                const userDiv = document.createElement('div');
                userDiv.style.cssText = 'align-self:flex-end; background:var(--brand-primary); color:white; padding:10px 14px; border-radius:12px 12px 0 12px; font-size:0.9rem; max-width:85%;';
                userDiv.textContent = text;
                body.appendChild(userDiv);
                
                // Simulated thinking
                setTimeout(() => {
                    const botDiv = document.createElement('div');
                    botDiv.style.cssText = 'align-self:flex-start; background:#252526; border:1px solid #3c3c3c; padding:10px 14px; border-radius:12px 12px 12px 0; color:#d4d4d4; font-size:0.9rem; max-width:85%;';
                    
                    // Simple FAQ Engine Logic
                    let reply = "Lo siento, actualmente no estoy conectado a una IA libre con OpenAI/Gemini. Solo puedo responder a comandos predefinidos. Por favor solicita al desarrollador la integración con IA Libre si deseas consultas sin límites.";
                    
                    const t = text.toLowerCase();
                    if(t.includes("factura") || t.includes("pro")) {
                        reply = "<b>Para Facturación PRO:</b><br>1. Ve a Facturación PRO en el menú.<br>2. Selecciona un cliente del listado.<br>3. Abajo verás los albaranes pendientes.<br>4. Marca los que desees incluir.<br>5. Pulsa 'Generar Factura DEFINITIVA'.";
                    } else if(t.includes("repartidor") || t.includes("chofer")) {
                        reply = "<b>App de Repartidor:</b><br>Los chóferes deben acceder desde su móvil ingresando su nombre tal cual aparece en 'Rutas / Carpetas'. Allí verán los albaranes asignados a su ruta diaria, podrán escanear QR's de estado e introducir la firma del destinatario.";
                    } else if(t.includes("debidos")) {
                        reply = "<b>Portes Debidos:</b><br>Al escanear un ticket sin asignar o recibir un albarán desde web marcado como 'Portes Debidos', este caerá en 'Facturación PRO' -> Pestaña 'Portes Debidos'. Debes asignarle un Cliente para que pase al flujo normal de facturación.";
                    } else if(t.includes("identidad") || t.includes("quien soy")) {
                        const iden = window.adminIdentity || "Administrador Anónimo";
                        reply = "Actualmente estás operando el sistema bajo la identidad: <b>" + iden + "</b>.";
                    }

                    botDiv.innerHTML = reply;
                    body.appendChild(botDiv);
                    body.scrollTop = body.scrollHeight;
                }, 800);
                
                body.scrollTop = body.scrollHeight;
            }
            
            // Re-update dynamic-identity-name when chat modal is opened if identity was chosen
            document.getElementById('ai-assistant-fab').addEventListener('click', () => {
                if(window.adminIdentity) {
                    document.querySelectorAll('.dynamic-identity-name').forEach(el => el.textContent = window.adminIdentity);
                }
            });
        </script>

        <!-- Usuarios View -->
        <div id="view-users" style="display:none">
            <div class="header">
                <h1>Gestión de Clientes Cloud</h1>
                <div style="display:flex; gap:10px; flex-wrap: wrap;">
                    <button class="btn btn-outline" onclick="syncAllTicketsIndices()"
                        title="Corregir vinculación de albaranes huérfanos">🔗 SINCRO GLOBAL</button>
                    <button class="btn btn-primary" id="btn-add-user"
                        onclick="if(window.openNewUserModal) window.openNewUserModal();">+ NUEVO CLIENTE</button>
                    <button class="btn btn-danger" onclick="deleteSelectedClients()">🗑️ ELIMINAR SELECCIONADOS</button>
                </div>
            </div>

            <!-- Buscador de Clientes -->
            <div id="client-search-bar" style="margin-bottom:20px; display:flex; gap:12px; align-items:center; background:var(--surface); border:1px solid var(--border-glass); border-radius:14px; padding:12px 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                <span style="font-size:1.3rem; opacity:0.7;">🔍</span>
                <input type="text" id="client-search-input" placeholder="Buscar por Nº, nombre, email, NIF, teléfono..." autocomplete="off"
                    style="flex:1; background:transparent; border:none; color:#fff; font-size:0.95rem; outline:none; padding:6px 0; font-family:var(--font-body);">
                <span id="client-search-count" style="font-size:0.75rem; color:var(--text-dim); white-space:nowrap;"></span>
                <button id="client-search-clear" onclick="document.getElementById('client-search-input').value=''; window._clientSearchFilter=''; loadUsers('first');" 
                    style="background:transparent; border:none; color:var(--text-dim); cursor:pointer; font-size:1.1rem; padding:4px 8px; display:none;" title="Limpiar búsqueda">✕</button>
            </div>


            <div class="table-responsive">
                <table class="user-list">
                    <thead>
                        <tr>
                            <th style="width:40px; text-align:center;"><input type="checkbox" id="user-select-all" onclick="toggleSelectAllClients(this)"></th>
                            <th>Nº ID</th>
                            <th>Cliente / Correo</th>
                            <th>Estado</th>
                            <th>Fecha Creación</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="user-table-body">
                        <!-- Loaded via JS -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination for Clients -->
            <div class="pagination-container" id="users-pagination"
                style="display:flex; justify-content:space-between; align-items:center; margin-top:15px; background:rgba(255,102,0,0.02); padding:10px; border-radius:10px; border:1px solid var(--border-glass);">
                <button class="btn btn-outline btn-sm" onclick="loadUsers('prev')" id="btn-users-prev">⬅️
                    Anterior</button>
                <span id="label-users-page" style="font-size:0.8rem; color:var(--text-dim); font-weight:bold;">Página
                    1</span>
                <button class="btn btn-outline btn-sm" onclick="loadUsers('next')" id="btn-users-next">Siguiente
                    ➡️</button>
            </div>
        </div>
        <!-- Pending Deletions View -->
        <div id="view-pending-deletes" style="display:none;">
            <div class="header" style="margin-bottom:15px;">
                <h1 style="color:#FF3B30;">🚨 Solicitudes de Anulación</h1>
                <button class="btn btn-outline" onclick="loadPendingDeletions()" title="Refrescar lista">🔄 ACTUALIZAR</button>
            </div>
            
            <div class="card" style="border: 1px solid #FF3B3055;">
                <p style="font-size:0.85rem; color:var(--text-dim); margin-bottom:20px;">Los siguientes albaranes han sido marcados con una solicitud de anulación por parte del cliente. Pulsa en el icono de la lupa para inspeccionarlos y conceder o denegar la solicitud.</p>
                <div class="table-responsive">
                    <table class="user-list">
                        <thead>
                            <tr>
                                <th>Albarán</th>
                                <th>Fecha</th>
                                <th>Cliente / Remitente</th>
                                <th>Motivo del Cliente</th>
                                <th>Estado</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody id="pending-deletions-body">
                            <!-- Loaded via JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Route Monitor View -->
        <div id="view-route-monitor" style="display:none;">
            <div class="header" style="margin-bottom:15px;">
                <h1>📍 Torre de Control de Rutas</h1>
                <button class="btn btn-outline" onclick="loadRouteMonitor()" title="Actualizar en tiempo real">🔄 ACTUALIZAR</button>
            </div>
            <p style="font-size:0.85rem; color:var(--text-dim); margin-bottom:20px;">Monitoriza el estado de los albaranes asignados a cada ruta. Haz clic en una ruta para ver y desasignar albaranes.</p>
            <div class="responsive-grid" id="route-monitor-grid">
                <!-- Cargado via JS -->
            </div>
        </div>

        <!-- Rutas View -->
        <div id="view-phones" style="display:none">
            <div class="header">
                <h1>Rutas y Repartidores</h1>
                <button class="btn btn-primary" id="btn-add-phone">+ NUEVA RUTA</button>
            </div>
            <div class="table-responsive">
                <table class="user-list">
                    <thead>
                        <tr>
                            <th>Localidad / Código Postal</th>
                            <th>Teléfono Repartidor</th>
                            <th>Nombre Chófer / Turno</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="phone-table-body">
                        <!-- Loaded via JS -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Configuración View -->
        <div id="view-config" style="display:none">


            <!-- Panel Multi-Filial -->
            <div class="card" style="margin-top:30px; border: 1px solid var(--brand-primary);">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h3 class="section-title" style="margin-top:0; color:var(--brand-primary); border-color:var(--brand-primary);">🏢 Empresas Emisoras (Filiales de Facturación)</h3>
                    <button class="btn btn-primary btn-sm" onclick="openAddBillingCompanyModal()">+ Nueva Filial</button>
                </div>
                <p style="font-size:0.85rem; color:var(--text-dim); margin-bottom:15px;">Gestiona las distintas razones sociales bajo las que factura NOVAPACK. Los Puntos de Origen y los clientes importados se ligarán a la entidad por defecto.</p>
                
                <div class="table-responsive">
                    <table class="user-list">
                        <thead>
                            <tr>
                                <th>Nombre Fiscal</th>
                                <th>CIF / NIF</th>
                                <th>Dirección</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="billing-companies-table-body">
                            <!-- Loaded via JS -->
                            <tr><td colspan="4" style="text-align:center;">Cargando filiales...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Panel GESCO Client Import -->
            <div class="card" style="margin-top:30px; border: 1px dashed #4CAF50;">
                <h3 class="section-title" style="margin-top:0; color:#4CAF50; border-color:#4CAF50;">🟢 Importación Masiva de Clientes (GESCO)</h3>
                <p style="font-size:0.85rem; color:var(--text-dim); margin-bottom:15px;">Sube el listado completo Excel/CSV de clientes extraído de GESCO para crear todas sus cuentas Cloud instantáneamente. Sus códigos nativos (ej: CLI:109) quedarán blindados para cruces automatizados mediante códigos QR en origen.</p>
                <div style="display:flex; align-items:center; gap: 15px;">
                    <input type="file" id="input-gesco-clients" accept=".csv, .xlsx, .xls" style="flex:1; padding: 10px; border:1px solid rgba(255,255,255,0.1); border-radius:8px; color:var(--text-bright);">
                    <button class="btn btn-primary" onclick="initiateGescoClientImport()" style="background:#4CAF50; border-color:#4CAF50;">📥 INICIAR IMPORTACIÓN</button>
                </div>
                <div id="gesco-client-import-log" style="margin-top:15px; font-size:0.8rem; font-family:monospace; background:rgba(0,0,0,0.5); padding:10px; border-radius:8px; display:none; max-height:200px; overflow-y:auto; color:#fff;"></div>
            </div>

            <div class="card" style="margin-top:30px; border: 1px solid #ff444452;">
                <h3 class="section-title" style="margin-top:0; color:#ff4444; border-color:#ff4444;">Zona de Peligro /
                    Mantenimiento</h3>
                <p style="font-size:0.8rem; color:#888; margin-bottom:15px;">Use estas opciones con extrema precaución.
                    Son irreversibles.</p>
                <button class="btn btn-danger" onclick="wipeAllOperationalData()" style="width:100%; padding:15px;">🧨
                    BORRAR TODOS LOS ALBARANES Y FACTURAS (EMPEZAR DE CERO)</button>
                <div style="font-size:0.7rem; color:#666; margin-top:10px; text-align:center;">Esto eliminará albaranes,
                    facturas y reiniciará contadores a 1. Los clientes y tarifas se mantienen.</div>

                <button class="btn btn-outline" onclick="repairDatabase()"
                    style="width:100%; margin-top:15px; border-color:#FF9800; color:#FF9800;">⚙️ REPARAR INTEGRIDAD DE
                    BASE DE DATOS Y PRIVILEGIOS</button>

                <button class="btn btn-danger" onclick="fullAppReset()"
                    style="width:100%; margin-top:15px; background:#ff4444; border:none; padding:20px; font-weight:900;">💣
                    HARD RESET (ELIMINAR TODO EXCEPTO ADMIN)</button>
                <div style="font-size:0.65rem; color:#ff4444; margin-top:10px; text-align:center; font-weight:bold;">
                    ESTA ACCIÓN ES EL NIVEL MÁXIMO DE REBORRADO</div>
            </div>

            <div class="card" style="margin-top:20px; font-size:0.75rem; color:#888;">
                <p>UID de Administrador: <span id="conf-admin-uid">...</span></p>
                <p>Proyecto ID: <span id="conf-project-id">...</span></p>
            </div>
        </div>
    </div>

    <!-- Scanner View -->
    <div id="view-qr-scanner-view" style="display:none">
        <div class="header">
            <h1 style="color:var(--brand-primary)">📷 Escáner de Albaranes</h1>
            <button class="btn btn-outline" onclick="showView('admin-tickets')">VOLVER A ALBARANES</button>
        </div>
        <div class="card"
            style="max-width: 600px; margin: 0 auto; text-align: center; border: 1px solid var(--brand-primary);">
            <p style="margin-bottom: 20px; color: var(--text-dim); font-size: 0.85rem;">Utiliza la cámara para escanear
                el QR del albarán y registrar su estado.</p>
            <div id="admin-qr-reader"
                style="width: 100%; min-height: 300px; border-radius:12px; overflow:hidden; border: 1px solid var(--brand-primary); margin-bottom: 20px; background: #000;">
            </div>

            <div id="scanned-result-area" class="hidden"
                style="text-align: left; padding: 20px; background: rgba(255,102,0,0.05); border-radius: 12px; border: 1px solid var(--brand-primary); animation: slideUp 0.3s ease-out;">
                <div
                    style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; border-bottom:1px solid rgba(255,102,0,0.2); padding-bottom:10px;">
                    <h3 id="scanned-id" style="color: var(--brand-primary); margin: 0; font-family: var(--font-logo);">
                        ALBARÁN: -</h3>
                    <span id="scanned-status-badge" class="status-badge"
                        style="background:#444; color:#fff;">ESTADO</span>
                </div>
                <div id="scanned-details" style="font-size: 0.95rem; line-height: 1.8; color: #eee;"></div>
                <button class="btn btn-primary" id="btn-mark-scanned"
                    style="width: 100%; margin-top: 25px; padding: 15px; font-weight:900;">✅ CONFIRMAR ENTREGA /
                    RECEPCIÓN</button>
            </div>
        </div>
    </div>

    <!-- Listados View -->
    

    <!-- MÓDULO UNIFICADO C-LEVEL: FACTURACIÓN -->
    

    <!-- Modelos Tributarios View -->
    <div id="view-tax-models" class="view-content" style="display:none">
        <div class="header">
            <h1>Modelos Tributarios (IVA / IRPF)</h1>
            <div style="display:flex; gap:10px;">
                <button class="btn btn-outline" id="btn-print-taxes" onclick="window.print()">🖨️ IMPRIMIR</button>
                <button class="btn btn-success" id="btn-email-taxes" onclick="sendTaxesByEmail()">📧 ENVIAR A
                    GESTORÍA</button>
            </div>
        </div>

        <div class="card responsive-grid" style="margin-bottom:20px; align-items:flex-end;">
            <div>
                <label>Trimestre / Periodo</label>
                <select id="tax-period-select" onchange="initTaxModelsView()">
                    <option value="1">1º Trimestre (Ene-Mar)</option>
                    <option value="2">2º Trimestre (Abr-Jun)</option>
                    <option value="3">3º Trimestre (Jul-Sep)</option>
                    <option value="4">4º Trimestre (Oct-Dic)</option>
                </select>
            </div>
            <div>
                <label>Año</label>
                <input type="number" id="tax-year-input" value="2026" onchange="initTaxModelsView()">
            </div>
            <div style="text-align:right;">
                <span style="font-size:0.7rem; color:#888;">Cálculo automático basado en facturas emitidas</span>
            </div>
        </div>

        <div id="printable-tax-area">
            <div id="tax-summary-container"></div>
        </div>
    </div>

    <!-- Maestro de Artículos View -->
    <div id="view-articles" class="view-content" style="display:none">
        <div class="header">
            <h1>Maestro de Artículos y Servicios</h1>
            <div
                style="display:flex; gap:10px; align-items:center; flex-wrap: wrap; width: 100%; justify-content: flex-end;">
                <input type="text" id="article-search" placeholder="Buscar artículo..."
                    oninput="filterArticles(this.value)" style="flex: 1; min-width: 200px;">
                <button class="btn btn-primary" onclick="openNewArticleModal()" style="white-space: nowrap;">+ NUEVO
                    ARTÍCULO</button>
            </div>
        </div>
        <div class="card">
            <div class="table-responsive">
                <table class="user-list">
                    <thead>
                        <tr>
                            <th>Artículo/Referencia</th>
                            <th>Descripción</th>
                            <th>Precio Base Sugerido</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="articles-master-body">
                        <!-- Loaded via JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Legacy views have been permanently relocated securely within 'view-billing' Module above. --> <!-- End Relocation Box -->

        <!-- Albaranes Manuales View -->
        <div id="view-admin-tickets" style="display:none">
            <div class="header">
                <h1 id="admin-tickets-title">Gestión de Albaranes por Cliente</h1>
                <div style="display:flex; gap:10px; flex-wrap: wrap; justify-content: flex-end;">
                    <button class="btn btn-outline" id="btn-import-gesco-alt"
                        style="border-color:var(--brand-primary); color:var(--brand-primary);">📦 IMPORTAR
                        GESCO</button>
                    <button class="btn btn-outline" id="btn-admin-view-list" onclick="setAdminTicketSubView('list')">📋
                        VER
                        LISTADO / FACTURAR</button>
                    <button class="btn btn-primary" id="btn-admin-view-create"
                        onclick="setAdminTicketSubView('create')">+
                        NUEVO ALBARÁN</button>
                    <button class="btn btn-outline" onclick="window.adminScannerMode='form'; showView('qr-scanner-view')"
                        style="border-color:var(--brand-primary); color:var(--brand-primary);">📷 ESCÁNER</button>
                    <button class="btn btn-outline" id="btn-import-json-alt" style="font-size: 0.6rem; opacity: 0.6;" onclick="if(window.openJSONImport) window.openJSONImport(); else alert('Error: The engine has not started yet. Reload the page.');">📥
                        RESTAURAR JSON</button>
                </div>
            </div>

            <div class="responsive-grid" style="grid-template-columns: 4fr 6fr;">
                <!-- Left Panel: Company Search & Selection -->
                <div class="card"
                    style="padding:15px; display:flex; flex-direction:column; max-height: calc(100vh - 180px);">
                    <h3 style="margin-top:0; font-size:1rem; color:var(--brand-primary)">Seleccionar Cliente</h3>
                    <div class="form-group" style="margin-bottom:10px;">
                        <input type="text" id="admin-ticket-client-search" class="form-control"
                            placeholder="Buscar por ID o Nombre...">
                    </div>
                    <div id="admin-client-list-container"
                        style="flex:1; overflow-y:auto; border:1px solid var(--border-glass); border-radius:6px;">
                        <select id="admin-ticket-client-select" class="form-control" size="20"
                            style="height:100%; border:none;"></select>
                    </div>

                    <div style="margin-top:20px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px;">
                            <h3 style="margin:0; font-size:1rem; color:var(--brand-primary)">Empresa Emisora Fiscal</h3>
                        </div>
                        <select id="admin-ticket-billing-entity" class="form-control" style="font-size: 1rem; font-weight: 700; color: var(--text-bright); padding: 10px; border: 1px dashed var(--brand-primary); cursor: pointer; background: rgba(255,100,0,0.05);">
                            <option value="">-- Por Defecto (Central) --</option>
                        </select>
                    </div>

                    <div style="margin-top:20px;">
                        <div
                            style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px;">
                            <h3 style="margin:0; font-size:1rem; color:var(--brand-primary)">Sede / Origen de Carga</h3>
                            <div>
                                <button class="btn btn-sm btn-outline" style="padding:2px 8px; font-size:0.7rem;"
                                    onclick="openManageCompaniesModal()">⚙️ SEDES</button>
                                <button class="btn btn-sm btn-outline" id="btn-admin-manage-agenda"
                                    style="padding:2px 8px; font-size:0.7rem; margin-left:5px; border-color:var(--brand-primary); color:var(--brand-primary);"
                                    onclick="openManageDestinationsModal()">📇 AGENDA</button>
                            </div>
                        </div>
                        <select id="admin-ticket-company-select" class="form-control" style="font-size: 1.2rem; font-weight: 900; background-color: rgba(76, 175, 80, 0.15); border: 2px solid var(--brand-primary); color: var(--text-bright); padding: 12px; height: auto; text-transform: uppercase; letter-spacing: 0.5px; box-shadow: 0 4px 15px rgba(76, 175, 80, 0.2); cursor: pointer; transition: all 0.2s ease;"></select>
                    </div>
                </div>

                <!-- Left Panel replaced modals with a holder if needed, but not really -->

                <!-- Right Panel: Dynamic Content -->
                <div id="admin-ticket-main-panel">
                    

                    <!-- Sub-view: Create -->
                    <div id="sub-view-admin-create" class="card" style="display:block;">
                        <h3
                            style="margin-top:0; color:var(--brand-primary); border-bottom: 1px solid var(--border-glass); padding-bottom: 10px; margin-bottom: 10px;">
                            📝 Crear Nuevo Albarán Manual
                        </h3>
                        
                        <form id="admin-manual-ticket-form">
                            <!-- Metadata Holder para IDs referenciados de QRs o Importaciones -->
                            <input type="hidden" id="admin-t-erp-id" value="">
                            
                            <!-- Info del Remitente (Lectura VISIBLE) -->
                            <div id="admin-t-sender-info"
                                style="margin-bottom:20px; padding:15px; background:linear-gradient(135deg, rgba(76, 175, 80, 0.15), rgba(76, 175, 80, 0.05)); border:3px solid var(--brand-primary); border-radius:10px; box-shadow: 0 4px 15px rgba(76, 175, 80, 0.15); text-align:center;">
                                <div id="admin-t-sender-label"
                                    style="font-size:0.9rem; color:var(--text-dim); font-weight:800; text-transform:uppercase; letter-spacing: 1px;">
                                    ⚠️ ESPERANDO SELECCIÓN DE CLIENTE Y SEDE...</div>
                                <div id="admin-t-sender-text"
                                    style="font-size:1.6rem; font-weight:900; color:var(--text-bright); margin-top:8px; text-transform:uppercase; line-height:1.2;">
                                    SELECCIONE EN EL PANEL IZQUIERDO</div>
                            </div>
                            
                            <!-- Input Escáner Pistola USB (Invisible o Discreto) -->
                            <div style="margin-bottom: 15px; text-align: center; display: none;">
                                <input type="text" id="manual-id-admin" class="scanner-input" 
                                    style="width:100%; max-width:400px; padding:12px; font-size:1.2rem; text-align:center; border:2px dashed var(--brand-primary); border-radius:8px; background:rgba(255,102,0,0.05);" 
                                    placeholder="📲 CLIC AQUÍ Y ESCANEA EL CÓDIGO QR / BARRAS" autocomplete="off" tabindex="-1">
                                <div style="font-size:0.75rem; color:#888; margin-top:5px;">El escáner USB debe estar configurado para enviar 'Enter' al final</div>
                                <!-- DEBUG AREA -->
                                <div id="admin-scanner-debug" style="margin-top:10px; padding:10px; font-family:monospace; font-size:0.8rem; color:#ff4444; background:#ffeebb; border:1px solid #ff4444; border-radius:4px; display:none; word-break:break-all;"></div>
                            </div>

                            <div
                                style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">

                                <!-- Columna 1: Datos de Entrega -->
                                <div style="display: flex; flex-direction: column; gap: 15px;">
                                    <div
                                        style="font-size: 0.7rem; font-weight: 900; color: var(--brand-primary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px;">
                                        📍 Datos de Entrega (Destinatario)
                                    </div>

                                    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 10px;">
                                        <div class="form-group" style="position:relative;">
                                            <label>Nombre / Cliente</label>
                                            <input type="text" id="admin-t-receiver" class="form-control" required
                                                placeholder="Nombre completo" autocomplete="off">
                                            <div id="admin-t-destinations-results" class="hidden"
                                                style="position:absolute; top:100%; left:0; right:0; background:var(--surface); border:1px solid var(--border-glass); z-index:1000; max-height:200px; overflow-y:auto; box-shadow:0 10px 20px rgba(0,0,0,0.5); border-radius:0 0 8px 8px;">
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label>Teléfono</label>
                                            <input type="text" id="admin-t-phone" class="form-control"
                                                placeholder="600 000 000">
                                        </div>
                                    </div>

                                    <div style="display: grid; grid-template-columns: 3fr 1fr; gap: 10px;">
                                        <div class="form-group">
                                            <label>Dirección (Calle / Avda)</label>
                                            <input type="text" id="admin-t-address" class="form-control" required
                                                placeholder="Calle...">
                                        </div>
                                        <div class="form-group">
                                            <label>Nº</label>
                                            <input type="text" id="admin-t-number" class="form-control"
                                                placeholder="123">
                                        </div>
                                    </div>

                                    <div style="display: grid; grid-template-columns: 2fr 1.2fr; gap: 10px;">
                                        <div class="form-group">
                                            <label>Localidad / Ciudad</label>
                                            <input type="text" id="admin-t-locality" class="form-control"
                                                placeholder="Población">
                                        </div>
                                        <div class="form-group">
                                            <label>Código Postal</label>
                                            <input type="text" id="admin-t-cp" class="form-control" placeholder="29600" required maxlength="5">
                                        </div>
                                    </div>

                                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
                                        <div class="form-group">
                                            <label>Provincia</label>
                                            <input type="text" id="admin-t-province" class="form-control"
                                                placeholder="Provincia">
                                        </div>
                                        <div class="form-group">
                                            <label>Turno Recomendado</label>
                                            <select id="admin-t-timeslot" class="form-control">
                                                <option value="MAÑANA">☀️ MAÑANA</option>
                                                <option value="TARDE">🌙 TARDE</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Repartidor (Teléfono)</label>
                                            <input type="tel" id="admin-t-driver-phone" class="form-control"
                                                placeholder="Ej: 600111222">
                                        </div>
                                    </div>
                                </div>

                                <!-- Columna 2: Detalles del Envío -->
                                <div style="display: flex; flex-direction: column; gap: 15px;">
                                    <div
                                        style="font-size: 0.7rem; font-weight: 900; color: var(--brand-primary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px;">
                                        📦 Detalles de la Carga y Cobro
                                    </div>

                                    <div class="form-group"
                                        style="background: rgba(0,0,0,0.15); padding: 15px; border-radius: 10px; border: 1px solid var(--border-glass);">
                                        <label style="margin-bottom: 12px; display: block;">Gestión de Bultos</label>
                                        <div style="display: flex; gap: 8px; margin-bottom: 12px;">
                                            <input type="number" id="admin-t-pkg-qty" class="form-control" value="1"
                                                style="width: 70px;">
                                            <input type="text" id="admin-t-pkg-size" class="form-control"
                                                placeholder="Ej: Bulto, Palet..." list="admin-suggested-sizes">
                                            <button type="button" class="btn btn-primary" id="btn-admin-add-pkg"
                                                style="padding: 10px;">+</button>
                                        </div>
                                        <div id="admin-t-packages-list"
                                            style="max-height: 120px; overflow-y: auto; display: flex; flex-direction: column; gap: 5px;">
                                        </div>
                                    </div>

                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                                        <div class="form-group">
                                            <label>Tipo de Portes</label>
                                            <select id="admin-t-shipping" class="form-control">
                                                <option value="Pagados">PAGADOS</option>
                                                <option value="Debidos">DEBIDOS</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Reembolso (€)</label>
                                            <input type="number" id="admin-t-cod" class="form-control" step="0.01"
                                                value="0">
                                        </div>
                                    </div>

                                    <div style="margin-top: auto; padding-top: 20px;">
                                        <button type="submit" class="btn btn-primary"
