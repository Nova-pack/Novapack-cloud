rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Permitir acceso de lectura publica a los recursos del proyecto si fueran necesarios
    // pero por ahora protegemos todo por defecto.
    
    // CHÓFERES - Firmas y fotos de entregas
    // Acceso autenticado (SMS o anónimo via master PIN)
    // Limite: 10MB, solo imágenes
    match /deliveries/{deliveryId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Cualquier otra cosa, prohibida por seguridad
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
