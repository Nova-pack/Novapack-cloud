rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users full access (admin app needs broad access)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    // Mail engine: allow write to mailbox without auth (for IMAP sync script)
    match /mailbox/{docId} {
      allow read, write: if true;
    }
  }
}
