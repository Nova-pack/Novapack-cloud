rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users full access (admin app needs broad access)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    // Mail engine: allow write to mailbox without auth (for IMAP sync script)
    // Read restricted to authenticated users (covered by global rule above)
    match /mailbox/{docId} {
      allow create, update: if true;
      allow read: if request.auth != null;
    }
    // Master PIN: allow read on config/phones for driver app PIN validation
    match /config/phones {
      allow read: if true;
    }
    match /config/phones/list/{docId} {
      allow read: if true;
    }
    // Deleted ticket blacklist: allow read for IMAP sync script
    match /deleted_erp_ids/{docId} {
      allow read: if true;
    }
  }
}
